<Window x:Class="QAMP.Visualization.SpectrumFullWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vis="clr-namespace:QAMP.Visualization"
        Title="SpectrumFullWindow"
        WindowStyle="None"
        WindowState="Maximized"
        Background="Black"
        ShowInTaskbar="False"
        KeyDown="SpectrumFullWindow_KeyDown"
        Loaded="SpectrumFullWindow_Loaded"
        Closed="SpectrumFullWindow_Closed">
    <Grid Background="Black">
        <vis:SpectrumControl x:Name="FullSpectrumViewer"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             Margin="0"/>
    </Grid>
</Window>
    