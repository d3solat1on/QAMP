<Window x:Class="QAMP.Dialogs.EditPlaylistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP.Dialogs"
        xmlns:converters="clr-namespace:QAMP.Converters"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="450"
        Height="550"
        Title="Редактировать плейлист"
        WindowStartupLocation="CenterOwner">
        <Window.Resources>
                <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
                <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
                <converters:NotNullConverter x:Key="NotNullConverter"/>
                <converters:LargeTrackImageConverter x:Key="LargeTrackImageConverter"/>
        </Window.Resources>

        <Border
                Background="#1A1A1A"
                CornerRadius="15"
                BorderBrush="#333"
                BorderThickness="1">
                <Border.Effect>
                        <DropShadowEffect BlurRadius="15"
                                          Direction="0"
                                          RenderingBias="Quality"
                                          ShadowDepth="0"
                                          Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="20">

                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Редактировать плейлист"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <Button Grid.Row="1"
                                Width="180"
                                Height="180"
                                Click="SelectCoverButton_Click"
                                Background="#282828">
                                <Grid>
                                        <Image x:Name="CoverImage"
                                               Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                               Stretch="UniformToFill"
                                               Margin="2">
                                                <Image.Style>
                                                        <Style TargetType="Image">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                                <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                     Value="{x:Null}">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                     Value="0">
                                                                                <Setter Property="Visibility"
                                                                                        Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Image.Style>
                                        </Image>
                                        <StackPanel VerticalAlignment="Center"
                                                    x:Name="PlaceholderText">
                                                <TextBlock Text="Изменить обложку"
                                                           Foreground="Gray"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"/>
                                        </StackPanel>
                                </Grid>
                        </Button>

                        <StackPanel Grid.Row="2"
                                    Margin="0,20">
                                <TextBlock Text="Название"
                                           Foreground="Gray"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="PlaylistNameTextBox"
                                         Background="#252525"
                                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="White"
                                         BorderThickness="0"
                                         Padding="10"
                                         Margin="0,0,0,15"/>

                                <TextBlock Text="Описание"
                                           Foreground="Gray"
                                           Margin="0,0,0,5"/>
                                <TextBox x:Name="PlaylistDescriptionTextBox"
                                         Background="#252525"
                                         Foreground="White"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Padding="10"
                                         Height="80"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                                <Button Content="Отмена"
                                        Click="CancelButton_Click"
                                        Width="100"
                                        Height="35"
                                        FontWeight="Bold"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="Black"
                                        Margin="0,0,10,0"
                                        IsCancel="True"
                                        BorderThickness="0">
                                        <Button.Resources>
                                                <Style TargetType="Border">
                                                        <Setter Property="CornerRadius"
                                                                Value="5"/>
                                                </Style>
                                        </Button.Resources>
                                </Button>
                                <Button Content="Сохранить"
                                        Click="EditPlaylist_Click"
                                        Width="100"
                                        Height="35"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="Black"
                                        FontWeight="Bold">
                                        <Button.Resources>
                                                <Style TargetType="Border">
                                                        <Setter Property="CornerRadius"
                                                                Value="5"/>
                                                </Style>
                                        </Button.Resources>
                                </Button>
                        </StackPanel>
                </Grid>
        </Border>
</Window>