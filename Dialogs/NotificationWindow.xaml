<Window x:Class="QAMP.Dialogs.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <Border Background="#1A1A1A"
            CornerRadius="10"
            BorderBrush="#333"
            BorderThickness="1"
            Padding="20">

        <StackPanel HorizontalAlignment="Center">
            <TextBlock x:Name="MessageText"
                       x:FieldModifier="public"
                       Foreground="White"
                       FontSize="14"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="300"/>

            <StackPanel x:Name="ConfirmButtons"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <Button x:Name="CancelButton"
                        Content="Отмена"
                        Click="Cancel_Click"
                        Width="100"
                        Height="32"
                        Margin="0,0,10,0"
                        Background="#333"
                        Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="16"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="DeleteButton"
                        Content="Да, удалить"
                        Click="Ok_Click"
                        Width="100"
                        Height="32"
                        Background="#E81123"
                        Foreground="White"
                        FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="16"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Button x:Name="SingleOkButton"
                    Content="OK"
                    Click="Ok_Click"
                    Visibility="Visible"
                    Width="100"
                    Height="32"
                    Background="#1DB954"
                    FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="16"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>