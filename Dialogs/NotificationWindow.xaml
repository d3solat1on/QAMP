<Window x:Class="QAMP.Dialogs.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
        <Grid>
                <Border x:Name="ToastBorder"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        CornerRadius="10"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="20,12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,110">
                        <Border.RenderTransform>
                                <TranslateTransform x:Name="ToastTranslate"
                                                    Y="0"/>
                        </Border.RenderTransform>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                                <TextBlock x:Name="MessageText"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="400"/>

                                <StackPanel x:Name="ConfirmButtons"
                                            Orientation="Horizontal"
                                            Visibility="Collapsed"
                                            Margin="15,0,0,0">
                                        <Button x:Name="CancelButton"
                                                Content="Отмена"
                                                Click="Cancel_Click"
                                                Width="80"
                                                Height="30"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource ModernPlayerButton}"/>
                                        <Button x:Name="DeleteButton"
                                                Content="Да"
                                                Click="Ok_Click"
                                                Width="80"
                                                Height="30"
                                                Style="{StaticResource ModernPlayerButton}"/>
                                </StackPanel>

                                <Button x:Name="SingleOkButton"
                                        Content="OK"
                                        Click="Ok_Click"
                                        Visibility="Collapsed"
                                        Margin="15,0,0,0"
                                        Width="60"
                                        Height="30"
                                        Style="{StaticResource ModernPlayerButton}"/>
                        </StackPanel>
                </Border>
        </Grid>
</Window>