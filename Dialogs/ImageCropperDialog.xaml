<Window x:Class="QAMP.Dialogs.ImageCropperDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="450"
        Height="550"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="CustomSliderStyle"
               TargetType="Slider">
            <Setter Property="Background"
                    Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4"
                                    Background="#333"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        Background="#1DB954"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14"
                                                         Height="14"
                                                         Fill="White"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="#1A1A1A"
            CornerRadius="15"
            BorderBrush="#333"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15"
                              Direction="0"
                              RenderingBias="Quality"
                              ShadowDepth="0"
                              Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Обрезать обложку"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Border Grid.Row="1"
                    Width="300"
                    Height="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#1DB954"
                    BorderThickness="2"
                    ClipToBounds="True">
                <Canvas x:Name="ContainerCanvas"
                        Background="Black"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        MouseWheel="ContainerCanvas_MouseWheel"
                        MouseMove="Canvas_MouseMove">
                    <Image x:Name="SourceImage"
                           Stretch="UniformToFill">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="ImageScale"
                                            CenterX="150"
                                            CenterY="150"/>
                        </Image.RenderTransform>
                    </Image>
                </Canvas>
            </Border>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,-25">
                <TextBlock Text="Масштаб"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           FontSize="10"/>
                <Slider x:Name="ZoomSlider"
                        Style="{StaticResource CustomSliderStyle}"
                        Minimum="0.1"
                        Maximum="3"
                        Value="1"
                        Width="250"
                        Margin="0,10,0,20"
                        ValueChanged="ZoomSlider_ValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Отмена"
                        Click="Cancel_Click"
                        Width="100"
                        Height="35"
                        FontWeight="Bold"
                        Background="#1DB954"
                        Foreground="Black"
                        Margin="0,0,10,0"
                        IsCancel="True"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Готово"
                        Click="Done_Click"
                        Width="100"
                        Height="35"
                        Background="#1DB954"
                        Foreground="Black"
                        FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>