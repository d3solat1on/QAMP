<Window x:Class="QAMP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svgc="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        xmlns:local="clr-namespace:QAMP"
        xmlns:converters="clr-namespace:QAMP.Converters"
        xmlns:viewModels="clr-namespace:QAMP.ViewModels"
        xmlns:services="clr-namespace:QAMP.Services"
        xmlns:models="clr-namespace:QAMP.Models"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="QAMP"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="GOST type A"
        Loaded="MainWindow_Loaded"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

        <WindowChrome.WindowChrome>
                <WindowChrome CaptionHeight="30"
                              GlassFrameThickness="0"
                              CornerRadius="0"/>
        </WindowChrome.WindowChrome>

        <Window.Resources>
                <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
                <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
                <converters:NotNullConverter x:Key="NotNullConverter"/>
                <converters:LargeTrackImageConverter x:Key="LargeTrackImageConverter"/>
                <converters:PercentOfConverter x:Key="PercentOfConverter"/>
                <BooleanToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
                <converters:BindingProxy x:Key="Proxy"
                                         Data="{Binding Source={x:Static models:SettingsManager.Instance}, Path=Config}"/>
        </Window.Resources>

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <!-- Строка заголовка -->
                        <RowDefinition Height="*"/>
                        <!-- Основной контент -->
                </Grid.RowDefinitions>

                <!-- Строка заголовка -->
                <Grid Grid.Row="0"
                      Background="{DynamicResource SecondaryBackgroundBrush}">
                        <!-- Название приложения слева (опционально) -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="QAMP"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Панель поиска в центре -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBox x:Name="SearchBox"
                                         Width="300"
                                         Height="24"
                                         Padding="8,4"
                                         Background="{DynamicResource TertiaryBackgroundBrush}"
                                         Foreground="{DynamicResource ForegroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Text=""
                                         KeyDown="SearchBox_KeyDown"/>
                                <Button x:Name="SearchButton"
                                        Width="30"
                                        Height="24"
                                        Margin="5,0,0,0"
                                        Background="{DynamicResource TertiaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        Click="SearchButton_Click">
                                        <Path Data="{StaticResource searchGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="ClearSearchButton"
                                        Width="30"
                                        Height="24"
                                        Margin="5,0,0,0"
                                        Background="{DynamicResource TertiaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource ForegroundBrush}"
                                        Click="ClearSearchButton_Click">
                                        <Path Data="{StaticResource closeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                        </StackPanel>

                        <!-- Кнопки управления справа -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button x:Name="Settings"
                                        Style="{StaticResource TitleBarButtonStyle}"
                                        Click="Settings_Click">
                                        <Path Data="{StaticResource settingsGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="BtnMinimize"
                                        Style="{StaticResource TitleBarButtonStyle}"
                                        Click="Minimize_Click">
                                        <Path Data="{StaticResource minimazeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>

                                <Button x:Name="BtnMaximize"
                                        Style="{StaticResource TitleBarButtonStyle}"
                                        Click="Maximize_Click">
                                        <Path Data="{StaticResource maximizeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="BtnClose"
                                        Style="{StaticResource CloseButtonStyle}"
                                        Click="Close_Click">
                                        <Path Data="{StaticResource closeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                        </StackPanel>
                </Grid>
                <DockPanel Grid.Row="1"
                           LastChildFill="True">
                        <!-- Нижняя панель с управлением -->
                        <Border DockPanel.Dock="Bottom"
                                ClipToBounds="False"
                                Height="100"
                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="15,0">
                                <Grid>
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">

                                                <!-- Кнопка избранного -->
                                                <Grid Height="40">
                                                        <Button x:Name="FavoriteButton"
                                                                Style="{StaticResource IconButton}"
                                                                Click="FavoriteButton_Click"
                                                                ToolTip="Добавить в избранное"
                                                                Width="40"
                                                                Height="40"
                                                                Margin="0,0,10,0">
                                                                <Path x:Name="FavoriteIcon"
                                                                      Width="25"
                                                                      Height="25"
                                                                      Data="{StaticResource favoriteGeometry}"
                                                                      Fill="{DynamicResource AccentBrush}"
                                                                      Stretch="Uniform"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                        </Button>
                                                </Grid>

                                                <!-- Информация о треке -->
                                                <StackPanel>
                                                        <TextBlock x:Name="LastTrackName"
                                                                   Text="Track Name"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="LastTrackExecutor"
                                                                   Text="Artist"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   FontSize="12"/>
                                                </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Margin="0,5"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                        <Grid Height="40">
                                                                <Button x:Name="Shuffle_button"
                                                                        Style="{StaticResource IconButton}"
                                                                        Click="ShuffleButton_Click"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0">
                                                                        <Path x:Name="ShuffleImage"
                                                                              Width="25"
                                                                              Height="25"
                                                                              Margin="5"
                                                                              Data="{StaticResource shuffleGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button Style="{StaticResource IconButton}"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0"
                                                                        Click="PrevButton_Click">
                                                                        <Path
                                                                                Width="25"
                                                                                Height="25"
                                                                                Margin="5"
                                                                                Data="{StaticResource fast_rewindGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button x:Name="PlayPauseButton"
                                                                        Style="{StaticResource IconButton}"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0"
                                                                        Click="PlayPauseButton_Click">
                                                                        <Path x:Name="PlayPauseIcon"
                                                                              Width="25"
                                                                              Height="25"
                                                                              Margin="5"
                                                                              Data="{StaticResource playGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button Style="{StaticResource IconButton}"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0"
                                                                        Click="NextButton_Click">
                                                                        <Path
                                                                                Width="25"
                                                                                Height="25"
                                                                                Margin="5"
                                                                                Data="{StaticResource fast_forwardGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button Style="{StaticResource IconButton}"
                                                                        Click="RepeatButton_Click"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0">
                                                                        <Path
                                                                                Width="25"
                                                                                Height="25"
                                                                                Margin="5"
                                                                                Data="{StaticResource loopGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button x:Name="ViewLyrics"
                                                                        Style="{StaticResource IconButton}"
                                                                        Click="ViewLyricsButton_Click"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0">
                                                                        <Path
                                                                                Width="25"
                                                                                Height="25"
                                                                                Margin="5"
                                                                                Data="{StaticResource lyricsGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                        </Grid>
                                                </StackPanel>

                                                <Grid Margin="20,5"
                                                      HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Текущее время -->
                                                        <TextBlock x:Name="CurrentTimeText"
                                                                   Grid.Column="0"
                                                                   Text="0:00"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"
                                                                   MinWidth="35"
                                                                   TextAlignment="Right"/>

                                                        <!-- Слайдер -->
                                                        <Slider x:Name="ProgressSlider"
                                                                Grid.Column="1"
                                                                Style="{StaticResource ModernSliderStyle}"
                                                                Minimum="0"
                                                                Maximum="100"
                                                                Thumb.DragStarted="ProgressSlider_DragStarted"
                                                                Thumb.DragCompleted="ProgressSlider_DragCompleted"
                                                                PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                                VerticalAlignment="Center"
                                                                Margin="0,5"/>

                                                        <!-- Общее время -->
                                                        <TextBlock x:Name="TotalTimeText"
                                                                   Grid.Column="2"
                                                                   Text="0:00"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0,0,0"
                                                                   MinWidth="35"/>
                                                </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    ClipToBounds="False"
                                                    Margin="0,0,15,0">

                                                <!-- Кнопка звука -->
                                                <Button x:Name="VolumeButton"
                                                        Style="{StaticResource VolumeButtonStyle}"
                                                        MouseDoubleClick="VolumeButton_MouseDoubleClick"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0">
                                                        <Path x:Name="VolumeImage"
                                                              Width="18"
                                                              Height="18"
                                                              Data="{StaticResource volumeGeometry}"
                                                              Fill="{DynamicResource AccentBrush}"
                                                              Stretch="Uniform"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Button>

                                                <!-- Слайдер громкости -->
                                                <Slider x:Name="VolumeSlider"
                                                        Style="{StaticResource ModernSliderStyle}"
                                                        ValueChanged="VolumeSlider_ValueChanged"
                                                        VerticalAlignment="Center"
                                                        Width="100"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        Margin="5,0,5,0"/>

                                                <!-- Процент громкости -->
                                                <TextBlock x:Name="VolumePercentage"
                                                           Text="50%"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                           FontSize="11"
                                                           FontFamily="Segoe UI"
                                                           Width="35"
                                                           TextAlignment="Right"/>
                                        </StackPanel>
                                </Grid>
                        </Border>

                        <!-- Основная область с тремя колонками -->

                        <Grid>

                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <!-- Левая колонка - плейлисты -->
                                <Border x:Name="LeftZona"
                                        Grid.Column="0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,1,0"
                                        Margin="0,0,0,0"
                                        Background="{DynamicResource TertiaryBackgroundBrush}">
                                        <StackPanel Margin="10">
                                                <DockPanel Margin="0,0,0,10">
                                                        <TextBlock Text="ПЛЕЙЛИСТЫ"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <StackPanel Orientation="Horizontal"
                                                                    DockPanel.Dock="Right">
                                                                <Button x:Name="CreatePlaylistButton"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Click="CreatePlaylistButton_Click"
                                                                        ToolTip="Создать плейлист">
                                                                        <Path
                                                                                Data="{StaticResource create_playlistGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                                <Button x:Name="RemovePlaylistButton"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Click="RemovePlaylist_Click"
                                                                        ToolTip="Удалить выбранный плейлист"
                                                                        IsEnabled="{Binding ElementName=PlaylistsListBox, Path=SelectedItem, Converter={StaticResource NotNullConverter}}">
                                                                        <Path
                                                                                Data="{StaticResource playlist_removeGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                                <Button
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Click="AddMusicButton_Click"
                                                                        ToolTip="Добавить музыку">
                                                                        <Button.Resources>
                                                                                <Style TargetType="ContextMenu"
                                                                                       x:Key="ModernMenu">
                                                                                        <Setter Property="Background"
                                                                                                Value="#1E1E1E"/>
                                                                                        <Setter Property="BorderBrush"
                                                                                                Value="#333"/>
                                                                                        <Setter Property="Template">
                                                                                                <Setter.Value>
                                                                                                        <ControlTemplate TargetType="ContextMenu">
                                                                                                                <Border Background="{TemplateBinding Background}"
                                                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                                        BorderThickness="1"
                                                                                                                        CornerRadius="8">
                                                                                                                        <StackPanel IsItemsHost="True"
                                                                                                                                    Margin="5"/>
                                                                                                                </Border>
                                                                                                        </ControlTemplate>
                                                                                                </Setter.Value>
                                                                                        </Setter>
                                                                                </Style>
                                                                        </Button.Resources>

                                                                        <Button.ContextMenu>
                                                                                <ContextMenu x:Name="AddMusicMenu"
                                                                                             Style="{StaticResource ModernMenu}">
                                                                                        <MenuItem x:Name="MenuAddFilesPlaylist"
                                                                                                  Click="AddFilesToPlaylist_Click"/>
                                                                                        <MenuItem x:Name="MenuAddFolderPlaylist"
                                                                                                  Click="AddFolderToPlaylist_Click"/>

                                                                                </ContextMenu>
                                                                        </Button.ContextMenu>

                                                                        <Path
                                                                                Data="{StaticResource add_musicGeometry}"
                                                                                Fill="{DynamicResource AccentBrush}"
                                                                                Stretch="Uniform"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                </Button>
                                                        </StackPanel>
                                                </DockPanel>

                                                <ListBox x:Name="PlaylistsListBox"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="White"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         SelectionChanged="PlaylistsListBox_SelectionChanged"
                                                         Height="Auto"
                                                         AllowDrop="True"
                                                         ItemsSource="{Binding Playlists, Source={x:Static local:ViewModels.MusicLibrary.Instance}}">
                                                        <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                        <EventSetter Event="PreviewMouseMove"
                                                                                     Handler="Playlist_MouseMove"/>
                                                                        <EventSetter Event="Drop"
                                                                                     Handler="Playlist_Drop"/>
                                                                        <Setter Property="Background"
                                                                                Value="Transparent"/>
                                                                        <Setter Property="BorderThickness"
                                                                                Value="0"/>
                                                                </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                                <DataTemplate>

                                                                        <Border BorderBrush="#333333"
                                                                                BorderThickness="0,0,0,1"
                                                                                Padding="8"
                                                                                Margin="0,2"
                                                                                Background="Transparent">
                                                                                <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="50"/>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                        </Grid.ColumnDefinitions>

                                                                                        <!-- Обложка плейлиста -->
                                                                                        <Border Grid.Column="0"
                                                                                                Width="45"
                                                                                                Height="45"
                                                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="4"
                                                                                                Background="{DynamicResource CentralPanelCardBackground}">
                                                                                                <Grid>
                                                                                                        <!-- Изображение (если есть) -->
                                                                                                        <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                                                               Stretch="UniformToFill"
                                                                                                               Margin="2">
                                                                                                                <Image.Style>
                                                                                                                        <Style TargetType="Image">
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Visible"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                                     Value="{x:Null}">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Collapsed"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                                     Value="0">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Collapsed"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </Image.Style>
                                                                                                        </Image>

                                                                                                        <!-- Текстовая иконка (если нет изображения) -->
                                                                                                        <TextBlock Text="📁"
                                                                                                                   FontSize="24"
                                                                                                                   HorizontalAlignment="Center"
                                                                                                                   VerticalAlignment="Center"
                                                                                                                   Foreground="#888888">
                                                                                                                <TextBlock.Style>
                                                                                                                        <Style TargetType="TextBlock">
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Collapsed"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                                     Value="{x:Null}">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Visible"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                                     Value="0">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Visible"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </TextBlock.Style>
                                                                                                        </TextBlock>
                                                                                                </Grid>
                                                                                        </Border>

                                                                                        <!-- Информация о плейлисте -->
                                                                                        <StackPanel
                                                                                                Grid.Column="1"
                                                                                                Margin="8,0,0,0"
                                                                                                VerticalAlignment="Center">

                                                                                                <StackPanel.ContextMenu>

                                                                                                        <ContextMenu Background="{DynamicResource ContextMenuBackground}"
                                                                                                                     Foreground="{DynamicResource ForegroundBrush}"
                                                                                                                     BorderBrush="{DynamicResource ContextMenuBorderBrush}">
                                                                                                                <ContextMenu.Resources>
                                                                                                                        <!-- 1. Убираем колонку иконок в самом ContextMenu -->
                                                                                                                        <Style TargetType="ContextMenu">
                                                                                                                                <Setter Property="Template">
                                                                                                                                        <Setter.Value>
                                                                                                                                                <ControlTemplate TargetType="ContextMenu">
                                                                                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                                                                                BorderThickness="1"
                                                                                                                                                                Padding="0">
                                                                                                                                                                <!-- Убираем лишние отступы -->
                                                                                                                                                                <!-- Используем StackPanel вместо стандартного ItemsPresenter -->
                                                                                                                                                                <StackPanel IsItemsHost="True"
                                                                                                                                                                            KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                                                                                                                        </Border>
                                                                                                                                                </ControlTemplate>
                                                                                                                                        </Setter.Value>
                                                                                                                                </Setter>
                                                                                                                        </Style>

                                                                                                                        <!-- 2. Ваш стиль для MenuItem (уже почти ок, добавим только привязку текста) -->
                                                                                                                        <Style TargetType="MenuItem">
                                                                                                                                <Setter Property="Template">
                                                                                                                                        <Setter.Value>
                                                                                                                                                <ControlTemplate TargetType="MenuItem">
                                                                                                                                                        <Border x:Name="Border"
                                                                                                                                                                Background="Transparent"
                                                                                                                                                                Padding="15,7">
                                                                                                                                                                <!-- Header — это то, что вы написали в MenuItem Header="..." -->
                                                                                                                                                                <ContentPresenter ContentSource="Header"
                                                                                                                                                                                  RecognizesAccessKey="True"/>
                                                                                                                                                        </Border>
                                                                                                                                                        <ControlTemplate.Triggers>
                                                                                                                                                                <Trigger Property="IsHighlighted"
                                                                                                                                                                         Value="True">
                                                                                                                                                                        <Setter TargetName="Border"
                                                                                                                                                                                Property="Background"
                                                                                                                                                                                Value="#3E3E3E"/>
                                                                                                                                                                </Trigger>
                                                                                                                                                        </ControlTemplate.Triggers>
                                                                                                                                                </ControlTemplate>
                                                                                                                                        </Setter.Value>
                                                                                                                                </Setter>
                                                                                                                        </Style>
                                                                                                                </ContextMenu.Resources>
                                                                                                                <MenuItem Header="Редактировать"
                                                                                                                          Click="EditPlaylist_Click"/>
                                                                                                                <MenuItem Header="Закрепить"
                                                                                                                          x:Name="PinPlaylistMenuItem"
                                                                                                                          Click="PinPlaylist_Click"/>
                                                                                                                <Separator Background="{DynamicResource BorderBrush}"/>
                                                                                                                <MenuItem Header="Удалить"
                                                                                                                          Click="DeletePlaylist_Click"
                                                                                                                          Foreground="Red"/>
                                                                                                        </ContextMenu>
                                                                                                </StackPanel.ContextMenu>
                                                                                                <StackPanel Orientation="Horizontal"
                                                                                                            VerticalAlignment="Center">
                                                                                                        <TextBlock Text="📌"
                                                                                                                   FontSize="12"
                                                                                                                   Margin="0,0,5,0"
                                                                                                                   Foreground="Orange">
                                                                                                                <TextBlock.Style>
                                                                                                                        <Style TargetType="TextBlock">
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Collapsed"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <DataTrigger Binding="{Binding IsPinned}"
                                                                                                                                                     Value="True">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Visible"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </TextBlock.Style>
                                                                                                        </TextBlock>
                                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                                   FontWeight="Bold"
                                                                                                                   FontSize="14"
                                                                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                                                </StackPanel>
                                                                                                <TextBlock Text="{Binding TrackCount, StringFormat='{}{0} треков'}"
                                                                                                           x:Name="CurrentTracksCountText"
                                                                                                           FontSize="10"
                                                                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                                                                           Margin="0,2,0,0"/>
                                                                                        </StackPanel>
                                                                                </Grid>
                                                                        </Border>
                                                                </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                </ListBox>
                                        </StackPanel>
                                </Border>



                                <Grid Grid.Column="1"
                                      Background="{DynamicResource TertiaryBackgroundBrush}">
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Padding="20"
                                                Background="{DynamicResource CentralPanelHeaderBackground}"
                                                BorderBrush="{DynamicResource GridHeaderSeperatorBrush}"
                                                BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">

                                                        <Border Width="150"
                                                                Height="150"
                                                                CornerRadius="4"
                                                                Background="{DynamicResource CentralPanelCardBackground}"
                                                                BorderBrush="{DynamicResource CentralPanelCardBorderBrush}"
                                                                BorderThickness="1"
                                                                Margin="0,0,20,0">
                                                                <Image
                                                                        x:Name="CurrentPlaylistCover"
                                                                        Stretch="UniformToFill"/>
                                                        </Border>

                                                        <StackPanel VerticalAlignment="Bottom">
                                                                <TextBlock Text="ПЛЕЙЛИСТ"
                                                                           Foreground="{DynamicResource CentralPanelHighlightForeground}"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Margin="0,0,0,5"/>

                                                                <TextBlock x:Name="CurrentPlaylistNameText"
                                                                           Foreground="{DynamicResource CentralPanelHighlightForeground}"
                                                                           FontSize="48"
                                                                           FontWeight="Black"
                                                                           Margin="0,0,0,10"/>

                                                                <TextBlock x:Name="CurrentPlaylistDescriptionText"
                                                                           Foreground="{DynamicResource CentralPanelSecondaryForeground}"
                                                                           FontSize="14"
                                                                           TextWrapping="Wrap"
                                                                           MaxWidth="500"/>

                                                                <TextBlock x:Name="CurrentTracksCountText"
                                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                                           FontSize="14"
                                                                           Margin="0,10,0,0"/>
                                                                <TextBlock x:Name="CurrentTracksTimeText"
                                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                                           FontSize="14"
                                                                           Margin="0,10,0,0"/>
                                                                <TextBlock x:Name="CurrentTracksDateCreateText"
                                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                                           FontSize="14"
                                                                           Margin="0,10,0,0"/>
                                                        </StackPanel>
                                                </StackPanel>
                                        </Border>

                                        <DataGrid x:Name="TracksDataGrid"
                                                  Visibility="Visible"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.IsDeferredScrollingEnabled="False"
                                                  VirtualizingStackPanel.ScrollUnit="Pixel"
                                                  VirtualizingStackPanel.CacheLength="2,3"
                                                  VirtualizingStackPanel.CacheLengthUnit="Page"
                                                  Grid.Row="1"
                                                  Background="Transparent"
                                                  RowBackground="{DynamicResource DataGridRowBackground}"
                                                  AlternatingRowBackground="{DynamicResource DataGridRowAltBackground}"
                                                  Foreground="{DynamicResource DataGridCellForeground}"
                                                  BorderBrush="{DynamicResource DataGridBorderBrush}"
                                                  BorderThickness="0"
                                                  AutoGenerateColumns="False"
                                                  CanUserResizeRows="False"
                                                  CanUserAddRows="False"
                                                  CanUserReorderColumns="False"
                                                  CanUserResizeColumns="False"
                                                  IsReadOnly="True"
                                                  SelectionMode="Single"
                                                  MouseDoubleClick="TracksDataGrid_MouseDoubleClick"
                                                  GridLinesVisibility="None"
                                                  AllowDrop="True"
                                                  DragOver="MainGrid_DragOver">
                                                <!-- Drop="MainGrid_Drop"> -->
                                                <DataGrid.ContextMenu>

                                                        <ContextMenu Background="{DynamicResource ContextMenuBackground}"
                                                                     BorderBrush="{DynamicResource ContextMenuBorderBrush}"
                                                                     Opened="ContextMenu_Opened">

                                                                <MenuItem Header="Воспроизвести"
                                                                          Click="PlayTrackMenuItem_Click"/>
                                                                <MenuItem Header="Информация"
                                                                          Click="ShowTrackInfo_Click"/>

                                                                <MenuItem Header="Добавить в плейлист"/>

                                                                <MenuItem Header="Удалить из плейлиста"
                                                                          Click="RemoveFromPlaylist_Click"/>
                                                        </ContextMenu>
                                                </DataGrid.ContextMenu>
                                                <DataGrid.Resources>
                                                        <Style TargetType="{x:Type DataGridRowHeader}">
                                                                <Setter Property="Background"
                                                                        Value="Transparent"/>
                                                                <Setter Property="BorderThickness"
                                                                        Value="0"/>
                                                                <Setter Property="Width"
                                                                        Value="0"/>
                                                        </Style>
                                                        <!-- Стиль для заголовков колонок -->
                                                        <Style TargetType="DataGridColumnHeader">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource DataGridHeaderBackground}"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource DataGridHeaderForeground}"/>
                                                                <Setter Property="FontWeight"
                                                                        Value="Bold"/>
                                                                <Setter Property="FontSize"
                                                                        Value="18"/>
                                                                <Setter Property="Height"
                                                                        Value="40"/>
                                                                <Setter Property="BorderBrush"
                                                                        Value="{DynamicResource GridHeaderSeperatorBrush}"/>
                                                                <Setter Property="BorderThickness"
                                                                        Value="0,0,1,1"/>
                                                                <Setter Property="HorizontalContentAlignment"
                                                                        Value="Left"/>
                                                                <Setter Property="Padding"
                                                                        Value="10,0,0,0"/>
                                                        </Style>

                                                        <!-- Стиль для ячеек -->
                                                        <Style TargetType="DataGridCell">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource DataGridCellBackground}"/>
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource DataGridCellForeground}"/>
                                                                <Setter Property="BorderBrush"
                                                                        Value="Transparent"/>
                                                                <Setter Property="VerticalAlignment"
                                                                        Value="Center"/>
                                                                <Setter Property="Padding"
                                                                        Value="10,5,0,5"/>
                                                                <Setter Property="FontSize"
                                                                        Value="18"/>
                                                                <Style.Triggers>
                                                                        <Trigger Property="IsSelected"
                                                                                 Value="True">
                                                                                <Setter Property="Background"
                                                                                        Value="{DynamicResource DataGridRowSelectedBackground}"/>
                                                                                <Setter Property="Foreground"
                                                                                        Value="{DynamicResource DataGridCellSelectedForeground}"/>
                                                                                <Setter Property="BorderBrush"
                                                                                        Value="{DynamicResource DataGridSelectionBorderBrush}"/>
                                                                        </Trigger>
                                                                </Style.Triggers>
                                                        </Style>

                                                        <!-- Стиль для строк -->
                                                        <Style TargetType="DataGridRow">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource DataGridRowBackground}"/>
                                                                <Setter Property="MinHeight"
                                                                        Value="35"/>
                                                                <Style.Triggers>
                                                                        <Trigger Property="AlternationIndex"
                                                                                 Value="1">
                                                                                <Setter Property="Background"
                                                                                        Value="{DynamicResource DataGridRowAltBackground}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected"
                                                                                 Value="True">
                                                                                <Setter Property="Background"
                                                                                        Value="{DynamicResource DataGridRowSelectedBackground}"/>
                                                                        </Trigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </DataGrid.Resources>
                                                <DataGrid.Columns>

                                                        <!-- В DataGrid.Columns, перед колонкой NAME -->
                                                        <DataGridTemplateColumn Header=""
                                                                                Visibility="{Binding Data.IsCompactMode, 
                 Source={StaticResource Proxy}, 
                 Converter={StaticResource InverseBoolToVisConverter}}"
                                                                                Width="75">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                                <Border Width="75"
                                                                                        Height="75"
                                                                                        CornerRadius="4"
                                                                                        BorderThickness="1"
                                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                                        Background="{DynamicResource CentralPanelCardBackground}">
                                                                                        <Grid>
                                                                                                <Path Data="{DynamicResource default_coverGeometry}"
                                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                                      Stretch="Uniform"
                                                                                                      Margin="15"
                                                                                                      HorizontalAlignment="Center"
                                                                                                      VerticalAlignment="Center"/>
                                                                                                <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                                                       Stretch="UniformToFill"
                                                                                                       HorizontalAlignment="Center"
                                                                                                       VerticalAlignment="Center">
                                                                                                        <Image.Style>
                                                                                                                <Style TargetType="Image">
                                                                                                                        <Setter Property="Visibility"
                                                                                                                                Value="Visible"/>
                                                                                                                        <Style.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                             Value="{x:Null}">
                                                                                                                                        <Setter Property="Visibility"
                                                                                                                                                Value="Collapsed"/>
                                                                                                                                </DataTrigger>
                                                                                                                                <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                             Value="0">
                                                                                                                                        <Setter Property="Visibility"
                                                                                                                                                Value="Collapsed"/>
                                                                                                                                </DataTrigger>
                                                                                                                        </Style.Triggers>
                                                                                                                </Style>
                                                                                                        </Image.Style>
                                                                                                </Image>
                                                                                        </Grid>
                                                                                </Border>
                                                                        </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>

                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="NAME"
                                                                            Binding="{Binding Name}"
                                                                            Width="3*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource DataGridCellForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                                        Value="Center"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>

                                                        <DataGridTextColumn Header="EXECUTOR"
                                                                            Binding="{Binding Executor}"
                                                                            Width="2*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource CentralPanelSecondaryForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                                        Value="Center"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>

                                                        <DataGridTextColumn Header="ALBUM"
                                                                            Binding="{Binding Album}"
                                                                            Width="2*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource CentralPanelSecondaryForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                                        Value="Center"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>

                                                        <DataGridTextColumn Header="DURATION"
                                                                            Binding="{Binding Duration}"
                                                                            Width="1*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                                        Value="Center"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>

                                                        <DataGridTextColumn Header="BITRATE"
                                                                            Binding="{Binding Bitrate}"
                                                                            Visibility="{Binding Data.IsCompactMode, 
                 Source={StaticResource Proxy}, 
                 Converter={StaticResource InverseBoolToVisConverter}}"
                                                                            Width="1*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                                <Setter Property="TextBlock.VerticalAlignment"
                                                                                        Value="Center"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="GENRE"
                                                                            Binding="{Binding Genre}"
                                                                            Visibility="{Binding Data.IsCompactMode, 
                 Source={StaticResource Proxy}, 
                 Converter={StaticResource InverseBoolToVisConverter}}"
                                                                            Width="1*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="DATE ADDED" 
                    Binding="{Binding AddedDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" 
                    Visibility="{Binding Data.IsCompactMode, Source={StaticResource Proxy}, Converter={StaticResource InverseBoolToVisConverter}}"
                                                                            Width="1*">
                                                                <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                                <Setter Property="TextBlock.Foreground"
                                                                                        Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                <Setter Property="TextBlock.Margin"
                                                                                        Value="10,0,0,0"/>
                                                                        </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                </DataGrid.Columns>
                                        </DataGrid>
                                        <Grid x:Name="LyricsOverlay"
                                              Visibility="Collapsed"
                                              Background="{DynamicResource TertiaryBackgroundBrush}">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <ScrollViewer x:Name="LyricsScrollViewer"
                                                              Grid.Row="0"
                                                              Margin="50,20"
                                                              Background="Transparent"
                                                              VerticalScrollBarVisibility="Auto"
                                                              CanContentScroll="False"
                                                              MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              Panel.ZIndex="1000">
                                                        <TextBlock x:Name="BigLyricsText"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Top"
                                                                   FontSize="32"
                                                                   Foreground="White"
                                                                   Padding="0,100,0,100"
                                                                   LineHeight="45"/>
                                                </ScrollViewer>
                                        </Grid>

                                </Grid>

                                <!-- Правая колонка - NOW PLAYING -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource TertiaryBackgroundBrush}"
                                        BorderThickness="1,0,0,0"
                                        BorderBrush="{DynamicResource BorderBrush}">
                                        <StackPanel VerticalAlignment="Top">
                                                <TextBlock Text="NOW PLAYING"
                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,20"/>

                                                <Border CornerRadius="8"
                                                        ClipToBounds="True"
                                                        Height="275"
                                                        Width="275"
                                                        Background="{DynamicResource CentralPanelCardBackground}"
                                                        BorderBrush="{DynamicResource CentralPanelCardBorderBrush}"
                                                        BorderThickness="1"
                                                        Margin="0,0,0,10">
                                                        <Image x:Name="CurrentTrackImage"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Source="{Binding ElementName=TracksDataGrid, Path=SelectedItem.CoverImage, Converter={StaticResource LargeTrackImageConverter}}"/>
                                                        <!-- XD moment  -->
                                                </Border>
                                                <TextBlock x:Name="CurrentTrackName"
                                                           Text="NAME"
                                                           FontSize="22"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource CentralPanelHighlightForeground}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="CurrentTrackExecutor"
                                                           Text="EXECUTOR"
                                                           FontSize="20"
                                                           Foreground="{DynamicResource CentralPanelSecondaryForeground}"
                                                           Margin="0,5"/>
                                                <TextBlock x:Name="CurrentTrackAlbum"
                                                           Text="ALBUM"
                                                           FontSize="20"
                                                           Foreground="{DynamicResource CentralPanelSecondaryForeground}"/>

                                                <TextBlock x:Name="CurrentTrackData"
                                                           Text="Genre | 00:00"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                           Margin="0,20,0,0"/>
                                                <TextBlock x:Name="CurrentTrackExtension"
                                                           Text="EXTENSION"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"/>
                                                <TextBlock x:Name="CurrentTrackYear"
                                                           Text="YEAR"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"/>
                                                <StackPanel x:Name="NextTrackPanel"
                                                            Margin="0,20,0,0">
                                                        <TextBlock Text="СЛЕДУЮЩИЙ ТРЕК:"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource CentralPanelSecondaryForeground}"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="NextTrackName"
                                                                   Text="Название трека..."
                                                                   FontSize="14"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <!-- <Canvas x:Name="SpectrumCanvas"
                                                        Height="100"
                                                        VerticalAlignment="Bottom"
                                                        Margin="10"
                                                        Background="Transparent">
                                                        <Polyline x:Name="SpectrumLine"
                                                                  Stroke="#1DB954"
                                                                  StrokeThickness="2"
                                                                  Points="0,100 400,100"/>
                                                </Canvas> -->
                                                <ItemsControl ItemsSource="{Binding PlayService.SpectrumViewModel.Bars}"
                                                              VerticalAlignment="Bottom"
                                                              HorizontalAlignment="Stretch"
                                                              Height="120"
                                                              Margin="10,0">
                                                        <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="{Binding SpectrumViewModel.Bars.Count, 
                     Source={x:Static services:PlayerService.Instance}}"
                                                                                     Rows="1"/>
                                                                </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                        <Border Width="Auto"
                                                                                Margin="1,0"
                                                                                Background="{DynamicResource AccentBrush}"
                                                                                VerticalAlignment="Bottom"
                                                                                CornerRadius="0"
                                                                                Height="{Binding Value}">
                                                                        </Border>
                                                                </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                        </StackPanel>
                                </Border>
                        </Grid>
                </DockPanel>
        </Grid>
</Window>