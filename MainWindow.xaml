<Window x:Class="QAMP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP"
        xmlns:converters="clr-namespace:QAMP.Converters"
        xmlns:viewModels="clr-namespace:QAMP.ViewModels"
        xmlns:services="clr-namespace:QAMP.Services"
        xmlns:models="clr-namespace:QAMP.Models"
        xmlns:vis="clr-namespace:QAMP.Visualization"
        xmlns:dialogs="clr-namespace:QAMP.Dialogs"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="QAMP"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="GOST type A"
        Loaded="MainWindow_Loaded"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

        <WindowChrome.WindowChrome>
                <WindowChrome CaptionHeight="30"
                              GlassFrameThickness="0"
                              CornerRadius="0"/>
        </WindowChrome.WindowChrome>

        <Window.Resources>
                <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
                <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
                <converters:NotNullConverter x:Key="NotNullConverter"/>
                <converters:LargeTrackImageConverter x:Key="LargeTrackImageConverter"/>
                <converters:PercentOfConverter x:Key="PercentOfConverter"/>
                <BooleanToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
                <converters:BindingProxy x:Key="Proxy"
                                         Data="{Binding Source={x:Static models:SettingsManager.Instance}, Path=Config}"/>
                <ObjectDataProvider x:Key="HeartProvider"
                                    ObjectType="{x:Type converters:FavoriteIconGenerate}"
                                    MethodName="GetHeartGeometry"/>
        </Window.Resources>

        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <!-- Строка заголовка -->
                        <RowDefinition Height="*"/>
                        <!-- Основной контент -->
                </Grid.RowDefinitions>

                <!-- Строка заголовка -->
                <Grid Grid.Row="0"
                      Background="{DynamicResource SecondaryBackgroundBrush}">
                        <!-- Название приложения слева (опционально) -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="10,0,0,0"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="QAMP"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontWeight="Bold"/>
                        </StackPanel>

                        <!-- Панель поиска в центре -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBox x:Name="SearchBox"
                                         Width="300"
                                         Height="30"
                                         Padding="8,4"
                                         Background="{DynamicResource TertiaryBackgroundBrush}"
                                         Foreground="{DynamicResource ForegroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Text=""
                                         KeyDown="SearchBox_KeyDown"/>
                                <Button x:Name="SearchButton"
                                        Style="{StaticResource IconButton}"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0,0,0"
                                        BorderThickness="1"
                                        Click="SearchButton_Click">
                                        <Path Data="{StaticResource searchGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="25"
                                              Height="25"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="ClearSearchButton"
                                        Style="{StaticResource IconButton}"
                                        Width="30"
                                        Height="30"
                                        Margin="5,0,0,0"
                                        BorderThickness="1"
                                        Click="ClearSearchButton_Click">
                                        <Path Data="{StaticResource closeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="25"
                                              Height="25"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                        </StackPanel>

                        <!-- Кнопки управления справа -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button x:Name="EqualizerButton"
                                        Style="{StaticResource IconButton}"
                                        ToolTip="Открыть параметры звука"
                                        Click="EqualizerButton_Click">
                                        <Path Data="{StaticResource EqualizerGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="Settings"
                                        Style="{StaticResource TitleBarButtonStyle}"
                                        Click="Settings_Click">
                                        <Path Data="{StaticResource settingsGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="BtnMinimize"
                                        Style="{StaticResource TitleBarButtonStyle}"
                                        Click="Minimize_Click">
                                        <Path Data="{StaticResource minimazeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>

                                <Button x:Name="BtnMaximize"
                                        Style="{StaticResource TitleBarButtonStyle}"
                                        Click="Maximize_Click">
                                        <Path Data="{StaticResource maximizeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                                <Button x:Name="BtnClose"
                                        Style="{StaticResource CloseButtonStyle}"
                                        Click="Close_Click">
                                        <Path Data="{StaticResource closeGeometry}"
                                              Fill="{DynamicResource AccentBrush}"
                                              Stretch="Uniform"
                                              Width="18"
                                              Height="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Button>
                        </StackPanel>
                </Grid>
                <DockPanel Grid.Row="1"
                           LastChildFill="True">
                        <!-- Нижняя панель с управлением -->
                        <Border DockPanel.Dock="Bottom"
                                ClipToBounds="False"
                                Height="100"
                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="15,0">
                                <Grid>
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Левая панель: избранное и информация о треке -->
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">

                                                <!-- Кнопка избранного -->
                                                <Grid x:Name="FavoriteButton1Grid"
                                                      Height="40">
                                                        <Button x:Name="FavoriteButton"
                                                                Style="{StaticResource IconButton}"
                                                                Click="FavoriteButton_Click"
                                                                ToolTip="Добавить в избранное"
                                                                Width="40"
                                                                Height="40"
                                                                Margin="0,0,10,0">
                                                                <Path x:Name="FavoriteIcon"
                                                                      Width="25"
                                                                      Height="25"
                                                                      Data="{StaticResource favoriteGeometry}"
                                                                      Fill="{DynamicResource AccentBrush}"
                                                                      Stretch="Uniform"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                        </Button>
                                                </Grid>

                                                <!-- Информация о треке -->
                                                <StackPanel>
                                                        <TextBlock x:Name="LastTrackName"
                                                                   Text=""
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"/>
                                                        <TextBlock x:Name="LastTrackExecutor"
                                                                   Text=""
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   FontSize="12"/>
                                                </StackPanel>
                                        </StackPanel>

                                        <!-- Центральная панель: кнопки управления -->
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="0,5"
                                                    VerticalAlignment="Center">

                                                <Grid HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Левая группа кнопок -->
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right">
                                                                <Grid Height="40">
                                                                        <Button x:Name="FullSpectrumWindowButton"
                                                                                Style="{StaticResource IconButton}"
                                                                                Click="FullSpectrumWindowButton_Click"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                ToolTip="Открыть спектр в полноэкранном режиме">
                                                                                <Path x:Name="FullSpectrumWindowImage"
                                                                                      Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource FullSpectrumWindowGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"/>
                                                                        </Button>
                                                                </Grid>
                                                                <Grid Height="40">
                                                                        <Button x:Name="Shuffle_button"
                                                                                Style="{StaticResource IconButton}"
                                                                                Click="ShuffleButton_Click"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                ToolTip="Включить перемешивание">
                                                                                <Path x:Name="ShuffleImage"
                                                                                      Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource shuffleGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"/>
                                                                        </Button>
                                                                </Grid>
                                                                <Grid Height="40">
                                                                        <Button Style="{StaticResource IconButton}"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                ToolTip="Предыдущий трек"
                                                                                Click="PrevButton_Click">
                                                                                <Path Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource fast_rewindGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>
                                                        </StackPanel>

                                                        <!-- Кнопка Play/Pause -->
                                                        <Grid Grid.Column="1"
                                                              HorizontalAlignment="Center">
                                                                <Grid Height="40">
                                                                        <Button x:Name="PlayPauseButton"
                                                                                Style="{StaticResource IconButton}"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                Click="PlayPauseButton_Click"
                                                                                ToolTip="Воспроизвести/пауза">
                                                                                <Path x:Name="PlayPauseIcon"
                                                                                      Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource playGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>
                                                        </Grid>

                                                        <!-- Правая группа кнопок -->
                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Left">
                                                                <Grid Height="40">
                                                                        <Button Style="{StaticResource IconButton}"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                Click="NextButton_Click"
                                                                                ToolTip="Следующий трек">
                                                                                <Path Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource fast_forwardGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>
                                                                <Grid Height="40">
                                                                        <Button Style="{StaticResource IconButton}"
                                                                                Click="RepeatButton_Click"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                ToolTip="Включить повтор">
                                                                                <Path x:Name="RepeatIcon"
                                                                                      Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource repeatGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>
                                                                <Grid Height="40">
                                                                        <Button x:Name="ViewLyrics"
                                                                                Style="{StaticResource IconButton}"
                                                                                Click="ViewLyricsButton_Click"
                                                                                Width="40"
                                                                                Height="40"
                                                                                Margin="5,0"
                                                                                ToolTip="Просмотреть тексты">
                                                                                <Path Width="25"
                                                                                      Height="25"
                                                                                      Margin="5"
                                                                                      Data="{StaticResource lyricsGeometry}"
                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                      Stretch="Uniform"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                        </Button>
                                                                </Grid>
                                                        </StackPanel>
                                                </Grid>

                                                <!-- Прогресс-бар -->
                                                <Grid Margin="20,5"
                                                      HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Текущее время -->
                                                        <TextBlock x:Name="CurrentTimeText"
                                                                   Grid.Column="0"
                                                                   Text="0:00"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,10,0"
                                                                   MinWidth="35"
                                                                   TextAlignment="Right"/>

                                                        <!-- Слайдер -->
                                                        <Slider x:Name="ProgressSlider"
                                                                Grid.Column="1"
                                                                Style="{StaticResource ModernSliderStyle}"
                                                                Minimum="0"
                                                                Maximum="100"
                                                                Thumb.DragStarted="ProgressSlider_DragStarted"
                                                                Thumb.DragCompleted="ProgressSlider_DragCompleted"
                                                                PreviewMouseLeftButtonDown="Slider_PreviewMouseLeftButtonDown"
                                                                VerticalAlignment="Center"
                                                                Margin="0,5"/>

                                                        <!-- Общее время -->
                                                        <TextBlock x:Name="TotalTimeText"
                                                                   Grid.Column="2"
                                                                   Text="0:00"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   FontSize="12"
                                                                   FontFamily="Segoe UI"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0,0,0"
                                                                   MinWidth="35"/>
                                                </Grid>
                                        </StackPanel>

                                        <!-- Правая панель: управление громкостью -->
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    ClipToBounds="False"
                                                    Margin="0,0,15,0">

                                                <!-- Кнопка звука -->
                                                <Button x:Name="VolumeButton"
                                                        Style="{StaticResource VolumeButtonStyle}"
                                                        MouseDoubleClick="VolumeButton_MouseDoubleClick"
                                                        Width="32"
                                                        Height="32"
                                                        Padding="0">
                                                        <Path x:Name="VolumeImage"
                                                              Width="18"
                                                              Height="18"
                                                              Data="{StaticResource volumeGeometry}"
                                                              Fill="{DynamicResource AccentBrush}"
                                                              Stretch="Uniform"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Button>

                                                <!-- Слайдер громкости -->
                                                <Slider x:Name="VolumeSlider"
                                                        Style="{StaticResource ModernSliderStyle}"
                                                        ValueChanged="VolumeSlider_ValueChanged"
                                                        VerticalAlignment="Center"
                                                        Width="100"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        Margin="5,0,5,0"/>

                                                <!-- Процент громкости -->
                                                <TextBlock x:Name="VolumePercentage"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                           FontSize="11"
                                                           FontFamily="Segoe UI"
                                                           Width="35"
                                                           TextAlignment="Right"/>
                                        </StackPanel>
                                </Grid>
                        </Border>

                        <!-- Основная область с тремя колонками -->

                        <Grid>

                                <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>

                                <!-- Левая колонка - плейлисты -->
                                <Border x:Name="LeftZona"
                                        Grid.Column="0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,1,0"
                                        Margin="0,0,0,0"
                                        Background="{DynamicResource TertiaryBackgroundBrush}">
                                        <Grid Margin="10">
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0"
                                                      Margin="10,0,10,15">
                                                        <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Grid.Row="0"
                                                                   Text="LIBRARY"
                                                                   FontSize="28"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,0,0,12"/>

                                                        <UniformGrid Grid.Row="1"
                                                                     Columns="4"
                                                                     Height="40">

                                                                <Button x:Name="SortByButton"
                                                                        Style="{StaticResource IconButton}"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Click="SortByButton_Click"
                                                                        ToolTip="Сортировать плейлисты">
                                                                        <Path Data="{StaticResource sortGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              Width="40"
                                                                              Height="40"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                </Button>

                                                                <Button x:Name="CreatePlaylistButton"
                                                                        Style="{StaticResource IconButton}"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Click="CreatePlaylistButton_Click"
                                                                        ToolTip="Создать плейлист">
                                                                        <Path Data="{StaticResource create_playlistGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              Width="40"
                                                                              Height="40"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                </Button>

                                                                <Button x:Name="RemovePlaylistButton"
                                                                        Style="{StaticResource IconButton}"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Click="RemovePlaylist_Click"
                                                                        ToolTip="Удалить выбранный плейлист"
                                                                        IsEnabled="{Binding ElementName=PlaylistsListBox, Path=SelectedItem, Converter={StaticResource NotNullConverter}}">
                                                                        <Path Data="{StaticResource playlist_removeGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              Width="40"
                                                                              Height="40"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                </Button>

                                                                <Button Style="{StaticResource IconButton}"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        Click="AddMusicButton_Click"
                                                                        ToolTip="Добавить музыку">
                                                                        <Button.Resources>
                                                                                <Style TargetType="ContextMenu"
                                                                                       x:Key="ModernMenu">
                                                                                        <Setter Property="Background"
                                                                                                Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                                                                        <Setter Property="BorderBrush"
                                                                                                Value="{DynamicResource AccentBrush}"/>
                                                                                        <Setter Property="Template">
                                                                                                <Setter.Value>
                                                                                                        <ControlTemplate TargetType="ContextMenu">
                                                                                                                <Border Background="{TemplateBinding Background}"
                                                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                                        BorderThickness="1"
                                                                                                                        CornerRadius="8">
                                                                                                                        <StackPanel IsItemsHost="True"
                                                                                                                                    Margin="5"/>
                                                                                                                </Border>
                                                                                                        </ControlTemplate>
                                                                                                </Setter.Value>
                                                                                        </Setter>
                                                                                </Style>
                                                                        </Button.Resources>

                                                                        <Button.ContextMenu>
                                                                                <ContextMenu x:Name="AddMusicMenu"
                                                                                             Style="{StaticResource ModernMenu}">
                                                                                        <MenuItem x:Name="MenuAddFilesPlaylist"
                                                                                                  Header="Добавить файлы"
                                                                                                  Click="AddFilesToPlaylist_Click"/>
                                                                                        <MenuItem x:Name="MenuAddFolderPlaylist"
                                                                                                  Header="Добавить папку"
                                                                                                  Click="AddFolderToPlaylist_Click"/>
                                                                                </ContextMenu>
                                                                        </Button.ContextMenu>

                                                                        <Path Data="{StaticResource add_musicGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              Width="40"
                                                                              Height="40"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                </Button>

                                                        </UniformGrid>
                                                </Grid>

                                                <!-- Placeholder для загрузки плейлистов -->
                                                <Grid Grid.Row="1"
                                                      x:Name="PlaylistsLoadingPlaceholder"
                                                      Visibility="Collapsed">
                                                        <StackPanel VerticalAlignment="Top"
                                                                    Margin="8">
                                                                <Border Height="45"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="45"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="45"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="45"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="45"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                        </StackPanel>
                                                </Grid>

                                                <ListBox Grid.Row="1"
                                                         x:Name="PlaylistsListBox"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="White"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         SelectionChanged="PlaylistsListBox_SelectionChanged"
                                                         Height="Auto"
                                                         AllowDrop="True"
                                                         ItemsSource="{Binding Playlists, Source={x:Static local:ViewModels.MusicLibrary.Instance}}">
                                                        <ListBox.ItemContainerStyle>
                                                                <Style TargetType="ListBoxItem">
                                                                        <EventSetter Event="PreviewMouseMove"
                                                                                     Handler="Playlist_MouseMove"/>
                                                                        <EventSetter Event="Drop"
                                                                                     Handler="Playlist_Drop"/>
                                                                        <Setter Property="Background"
                                                                                Value="Transparent"/>
                                                                        <Setter Property="BorderThickness"
                                                                                Value="0"/>
                                                                </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                                <DataTemplate>

                                                                        <Border BorderBrush="#333333"
                                                                                BorderThickness="0,0,0,1"
                                                                                Padding="8"
                                                                                Margin="0,2"
                                                                                Background="Transparent">
                                                                                <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                                <ColumnDefinition Width="50"/>
                                                                                                <ColumnDefinition Width="*"/>
                                                                                        </Grid.ColumnDefinitions>

                                                                                        <!-- Обложка плейлиста -->
                                                                                        <Border Grid.Column="0"
                                                                                                Width="45"
                                                                                                Height="45"
                                                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                                                BorderThickness="1"
                                                                                                CornerRadius="4"
                                                                                                Background="{DynamicResource CentralPanelCardBackground}">
                                                                                                <Grid>
                                                                                                        <!-- Изображение (если есть) -->
                                                                                                        <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                                                               Stretch="UniformToFill"
                                                                                                               Margin="2">
                                                                                                                <Image.Style>
                                                                                                                        <Style TargetType="Image">
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Visible"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                                     Value="{x:Null}">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Collapsed"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                                     Value="0">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Collapsed"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </Image.Style>
                                                                                                        </Image>
                                                                                                        <!-- Текстовая иконка (если нет изображения) -->
                                                                                                        <Grid x:Name="PlaylistPlaceholderContainer">
                                                                                                                <Grid.Style>
                                                                                                                        <Style TargetType="Grid">
                                                                                                                                <!-- По умолчанию скрываем весь контейнер заглушки -->
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Collapsed"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <!-- Показываем, если CoverImage равен null -->
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                                     Value="{x:Null}">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Visible"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                        <!-- Показываем, если строка пути/массив пустой (длина 0) -->
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                                     Value="0">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Visible"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </Grid.Style>
                                                                                                                <!-- Сама иконка, которая управляет своей геометрией -->
                                                                                                                <Path Fill="{DynamicResource AccentBrush}"
                                                                                                                      HorizontalAlignment="Center"
                                                                                                                      VerticalAlignment="Center"
                                                                                                                      Stretch="Uniform">
                                                                                                                        <Path.Style>
                                                                                                                                <Style TargetType="Path">
                                                                                                                                        <!-- Геометрия по умолчанию (обычная заглушка) -->
                                                                                                                                        <Setter Property="Data"
                                                                                                                                                Value="{StaticResource PlugForTheRightSideGeometry}"/>
                                                                                                                                        <Style.Triggers>
                                                                                                                                                <!-- Если это избранное (Id = 1), меняем геометрию -->
                                                                                                                                                <DataTrigger Binding="{Binding Id}"
                                                                                                                                                             Value="1">
                                                                                                                                                        <Setter Property="Data"
                                                                                                                                                                Value="{StaticResource FavoriteCoverGeometry}"/>
                                                                                                                                                        <Setter Property="Effect">
                                                                                                                                                                <Setter.Value>
                                                                                                                                                                        <DropShadowEffect Color="{Binding Source={StaticResource AccentBrush}, Path=Color}"
                                                                                                                                                                                          BlurRadius="15"
                                                                                                                                                                                          ShadowDepth="0"
                                                                                                                                                                                          Opacity="0.5"/>
                                                                                                                                                                </Setter.Value>
                                                                                                                                                        </Setter>
                                                                                                                                                </DataTrigger>
                                                                                                                                        </Style.Triggers>
                                                                                                                                </Style>
                                                                                                                        </Path.Style>
                                                                                                                </Path>
                                                                                                        </Grid>
                                                                                                </Grid>
                                                                                        </Border>

                                                                                        <!-- Информация о плейлисте -->
                                                                                        <StackPanel
                                                                                                Grid.Column="1"
                                                                                                Margin="8,0,0,0"
                                                                                                VerticalAlignment="Center">

                                                                                                <StackPanel.ContextMenu>

                                                                                                        <ContextMenu Background="{DynamicResource ContextMenuBackground}"
                                                                                                                     Foreground="{DynamicResource ForegroundBrush}"
                                                                                                                     BorderBrush="{DynamicResource ContextMenuBorderBrush}">
                                                                                                                <ContextMenu.Resources>
                                                                                                                        <!-- 1. Убираем колонку иконок в самом ContextMenu -->
                                                                                                                        <Style TargetType="ContextMenu">
                                                                                                                                <Setter Property="Template">
                                                                                                                                        <Setter.Value>
                                                                                                                                                <ControlTemplate TargetType="ContextMenu">
                                                                                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                                                                                BorderThickness="1"
                                                                                                                                                                Padding="0">
                                                                                                                                                                <!-- Убираем лишние отступы -->
                                                                                                                                                                <!-- Используем StackPanel вместо стандартного ItemsPresenter -->
                                                                                                                                                                <StackPanel IsItemsHost="True"
                                                                                                                                                                            KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                                                                                                                        </Border>
                                                                                                                                                </ControlTemplate>
                                                                                                                                        </Setter.Value>
                                                                                                                                </Setter>
                                                                                                                        </Style>

                                                                                                                        <!-- 2. Ваш стиль для MenuItem (уже почти ок, добавим только привязку текста) -->
                                                                                                                        <Style TargetType="MenuItem">
                                                                                                                                <Setter Property="Template">
                                                                                                                                        <Setter.Value>
                                                                                                                                                <ControlTemplate TargetType="MenuItem">
                                                                                                                                                        <Border x:Name="Border"
                                                                                                                                                                Background="Transparent"
                                                                                                                                                                Padding="15,7">
                                                                                                                                                                <!-- Header — это то, что вы написали в MenuItem Header="..." -->
                                                                                                                                                                <ContentPresenter ContentSource="Header"
                                                                                                                                                                                  RecognizesAccessKey="True"/>
                                                                                                                                                        </Border>
                                                                                                                                                        <ControlTemplate.Triggers>
                                                                                                                                                                <Trigger Property="IsHighlighted"
                                                                                                                                                                         Value="True">
                                                                                                                                                                        <Setter TargetName="Border"
                                                                                                                                                                                Property="Background"
                                                                                                                                                                                Value="#3E3E3E"/>
                                                                                                                                                                </Trigger>
                                                                                                                                                        </ControlTemplate.Triggers>
                                                                                                                                                </ControlTemplate>
                                                                                                                                        </Setter.Value>
                                                                                                                                </Setter>
                                                                                                                        </Style>
                                                                                                                </ContextMenu.Resources>
                                                                                                                <MenuItem Header="Редактировать"
                                                                                                                          Click="EditPlaylist_Click"/>
                                                                                                                <MenuItem x:Name="PinPlaylistMenuItem"
                                                                                                                          Click="PinPlaylist_Click">
                                                                                                                        <MenuItem.Style>
                                                                                                                                <Style TargetType="MenuItem"
                                                                                                                                       BasedOn="{StaticResource {x:Type MenuItem}}">
                                                                                                                                        <Setter Property="Header"
                                                                                                                                                Value="Закрепить"/>
                                                                                                                                        <Style.Triggers>
                                                                                                                                                <DataTrigger Binding="{Binding IsPinned}"
                                                                                                                                                             Value="True">
                                                                                                                                                        <Setter Property="Header"
                                                                                                                                                                Value="Открепить"/>
                                                                                                                                                </DataTrigger>
                                                                                                                                        </Style.Triggers>
                                                                                                                                </Style>
                                                                                                                        </MenuItem.Style>
                                                                                                                </MenuItem>
                                                                                                                <MenuItem Header="Информация"
                                                                                                                          Click="ShowPlaylistInfo_Click"/>
                                                                                                                <MenuItem Header="Обновить плейлист"
                                                                                                                          ToolTip="Пересканировать папки плейлиста и обновить его содержимое(Если это не произошло автоматически)"
                                                                                                                          Click="RefreshPlaylist_Click"/>
                                                                                                                <Separator Background="{DynamicResource BorderBrush}"/>
                                                                                                                <MenuItem Header="Удалить"
                                                                                                                          Click="DeletePlaylist_Click"
                                                                                                                          Foreground="Red"/>
                                                                                                        </ContextMenu>
                                                                                                </StackPanel.ContextMenu>
                                                                                                <StackPanel Orientation="Horizontal"
                                                                                                            VerticalAlignment="Center">
                                                                                                        <Viewbox x:Name="PinForPlaylistContainer"
                                                                                                                 Width="14"
                                                                                                                 Height="14"
                                                                                                                 Margin="0,0,5,0"
                                                                                                                 VerticalAlignment="Center">

                                                                                                                <Path x:Name="PinForPlaylist"
                                                                                                                      Data="{StaticResource PinForPlaylistGeometry}"
                                                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                                                      Stretch="Uniform"/>

                                                                                                                <Viewbox.Style>
                                                                                                                        <Style TargetType="Viewbox">
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Collapsed"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <DataTrigger Binding="{Binding IsPinned}"
                                                                                                                                                     Value="True">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Visible"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </Viewbox.Style>
                                                                                                        </Viewbox>
                                                                                                        <TextBlock Text="{Binding Name}"
                                                                                                                   FontWeight="Bold"
                                                                                                                   FontSize="14"
                                                                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                                                </StackPanel>
                                                                                                <TextBlock Text="{Binding TrackCount, StringFormat='{}{0} треков'}"
                                                                                                           x:Name="CurrentTracksCountText"
                                                                                                           FontSize="10"
                                                                                                           Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                                                                           Margin="0,2,0,0"/>
                                                                                        </StackPanel>
                                                                                </Grid>
                                                                        </Border>
                                                                </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                </ListBox>
                                        </Grid>
                                </Border>



                                <Grid Grid.Column="1"
                                      Background="{DynamicResource TertiaryBackgroundBrush}">
                                        <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border x:Name="UpperPanel"
                                                Grid.Row="0"
                                                Padding="20"
                                                Background="{DynamicResource CentralPanelHeaderBackground}"
                                                BorderBrush="{DynamicResource GridHeaderSeperatorBrush}"
                                                BorderThickness="0,0,0,1">

                                                <Grid Height="160">
                                                        <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="150"
                                                                Height="150"
                                                                CornerRadius="4"
                                                                VerticalAlignment="Top"
                                                                Background="{DynamicResource CentralPanelCardBackground}"
                                                                BorderBrush="{DynamicResource CentralPanelCardBorderBrush}"
                                                                BorderThickness="1"
                                                                Margin="0,0,20,0"
                                                                ClipToBounds="True">
                                                                <ContentControl>
                                                                        <ContentControl.Style>
                                                                                <Style TargetType="ContentControl">
                                                                                        <Setter Property="Content">
                                                                                                <Setter.Value>
                                                                                                        <Image Source="{Binding CurrentPlaylist.CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                                                               Stretch="UniformToFill"/>
                                                                                                </Setter.Value>
                                                                                        </Setter>

                                                                                        <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding CurrentPlaylist.CoverImage}"
                                                                                                             Value="{x:Null}">
                                                                                                        <Setter Property="Content">
                                                                                                                <Setter.Value>
                                                                                                                        <Grid Background="{DynamicResource CentralPanelCardBackground}">
                                                                                                                                <Path Data="{StaticResource PlugForTheCoverPlaylistGeometry}"
                                                                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                                                                      Opacity="1"
                                                                                                                                      Stretch="Uniform"
                                                                                                                                      Margin="5"
                                                                                                                                      VerticalAlignment="Center"
                                                                                                                                      HorizontalAlignment="Center"/>
                                                                                                                        </Grid>
                                                                                                                </Setter.Value>
                                                                                                        </Setter>
                                                                                                </DataTrigger>

                                                                                                <DataTrigger Binding="{Binding CurrentPlaylist.Name}"
                                                                                                             Value="Избранное">
                                                                                                        <Setter Property="Content">
                                                                                                                <Setter.Value>
                                                                                                                        <Grid Background="{DynamicResource CentralPanelCardBackground}">
                                                                                                                                <Path Data="{Binding Source={StaticResource HeartProvider}}"
                                                                                                                                      Fill="{DynamicResource AccentBrush}"
                                                                                                                                      Stretch="Uniform"
                                                                                                                                      Margin="25"
                                                                                                                                      VerticalAlignment="Center"
                                                                                                                                      HorizontalAlignment="Center">
                                                                                                                                        <Path.Effect>
                                                                                                                                                <DropShadowEffect Color="{Binding Source={StaticResource AccentBrush}, Path=Color}"
                                                                                                                                                                  BlurRadius="15"
                                                                                                                                                                  ShadowDepth="0"
                                                                                                                                                                  Opacity="0.5"/>
                                                                                                                                        </Path.Effect>
                                                                                                                                </Path>
                                                                                                                        </Grid>
                                                                                                                </Setter.Value>
                                                                                                        </Setter>
                                                                                                </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                </Style>
                                                                        </ContentControl.Style>
                                                                </ContentControl>
                                                        </Border>
                                                        <Grid Grid.Column="1">
                                                                <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock x:Name="PlaylistRS"
                                                                           Grid.Row="0"
                                                                           Text="ПЛЕЙЛИСТ"
                                                                           Foreground="{DynamicResource CentralPanelHighlightForeground}"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Margin="0,0,0,2"/>

                                                                <TextBlock Grid.Row="1"
                                                                           Text="{Binding CurrentPlaylist.Name}"
                                                                           Foreground="{DynamicResource CentralPanelHighlightForeground}"
                                                                           FontSize="44"
                                                                           FontWeight="Black"
                                                                           Margin="0,0,0,5"
                                                                           TextTrimming="CharacterEllipsis"/>

                                                                <TextBlock Grid.Row="2"
                                                                           Text="{Binding CurrentPlaylist.Description}"
                                                                           Foreground="{DynamicResource CentralPanelSecondaryForeground}"
                                                                           FontSize="14"
                                                                           TextWrapping="Wrap"
                                                                           VerticalAlignment="Top"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxWidth="600"
                                                                           HorizontalAlignment="Left"/>

                                                                <StackPanel Grid.Row="3"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Bottom">
                                                                        <TextBlock Text="{Binding CurrentPlaylist.TrackCountDisplay, StringFormat='Треков: {0}'}"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   FontSize="13"/>
                                                                        <TextBlock Text=" • "
                                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                                        <TextBlock Text="{Binding CurrentPlaylist.TotalDurationDisplay}"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   FontSize="13"/>
                                                                        <TextBlock Text=" • "
                                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                                        <TextBlock Text="{Binding CurrentPlaylist.CreatedDate, StringFormat=\{0:dd\\.MM\\.yyyy\}}"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   FontSize="13"/>
                                                                </StackPanel>
                                                        </Grid>
                                                </Grid>
                                        </Border>
                                        <Border x:Name="ControlsPanel"
                                                Grid.Row="1"
                                                Padding="10"
                                                Background="{DynamicResource CentralPanelHeaderBackground}"
                                                BorderBrush="{DynamicResource GridHeaderSeperatorBrush}"
                                                BorderThickness="0,0,0,1">
                                                <StackPanel VerticalAlignment="Bottom"
                                                            Orientation="Horizontal"
                                                            Margin="0,20,0,0">
                                                        <Grid Height="40">
                                                                <Button x:Name="PlayPauseButton1"
                                                                        Style="{StaticResource IconButton}"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0"
                                                                        Click="PlayPlaylistButton_Click">
                                                                        <Path x:Name="PlayPauseIcon1"
                                                                              Width="25"
                                                                              Height="25"
                                                                              Margin="5"
                                                                              Data="{StaticResource playGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button x:Name="Shuffle_button1"
                                                                        Style="{StaticResource IconButton}"
                                                                        Click="ShuffleButton_Click"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0">
                                                                        <Path x:Name="ShuffleImage1"
                                                                              Width="25"
                                                                              Height="25"
                                                                              Margin="5"
                                                                              Data="{StaticResource shuffleGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"/>
                                                                </Button>
                                                        </Grid>
                                                        <Grid Height="40">
                                                                <Button x:Name="Sort_button1"
                                                                        Style="{StaticResource IconButton}"
                                                                        Click="SortButton_Click"
                                                                        Width="40"
                                                                        Height="40"
                                                                        Margin="5,0">
                                                                        <Path x:Name="sortImage1"
                                                                              Width="25"
                                                                              Height="25"
                                                                              Margin="5"
                                                                              Data="{StaticResource sortGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"/>
                                                                </Button>
                                                        </Grid>
                                                </StackPanel>
                                        </Border>

                                        <Grid Grid.Row="2">
                                                <!-- Placeholder для загрузки треков -->
                                                <Grid x:Name="TracksLoadingPlaceholder"
                                                      Visibility="Collapsed"
                                                      Background="{DynamicResource TertiaryBackgroundBrush}">
                                                        <StackPanel VerticalAlignment="Top"
                                                                    Margin="20">
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                                <Border Height="35"
                                                                        Margin="0,5"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"/>
                                                        </StackPanel>
                                                </Grid>

                                                <DataGrid x:Name="TracksDataGrid"
                                                          AlternationCount="2"
                                                          AllowDrop="True"
                                                          MouseDoubleClick="TracksDataGrid_MouseDoubleClick"
                                                          DragOver="MainGrid_DragOver">
                                                        <!-- Drop="MainGrid_Drop"> -->
                                                        <DataGrid.ContextMenu>
                                                                <ContextMenu Background="{DynamicResource ContextMenuBackground}"
                                                                             BorderBrush="{DynamicResource ContextMenuBorderBrush}"
                                                                             Opened="ContextMenu_Opened">
                                                                        <MenuItem Header="Воспроизвести"
                                                                                  Click="PlayTrackMenuItem_Click"/>
                                                                        <MenuItem Header="Информация"
                                                                                  Click="ShowTrackInfo_Click"/>
                                                                        <MenuItem Header="Добавить в плейлист"/>
                                                                        <MenuItem Header="Удалить из плейлиста"
                                                                                  Click="RemoveFromPlaylist_Click"/>
                                                                </ContextMenu>
                                                        </DataGrid.ContextMenu>
                                                        <DataGrid.Resources>
                                                                <Style TargetType="{x:Type DataGridRowHeader}">
                                                                        <Setter Property="Background"
                                                                                Value="Transparent"/>
                                                                        <Setter Property="BorderThickness"
                                                                                Value="0"/>
                                                                        <Setter Property="Width"
                                                                                Value="0"/>
                                                                </Style>
                                                                <!-- Стиль для заголовков колонок -->
                                                                <Style TargetType="DataGridColumnHeader">
                                                                        <Setter Property="Background"
                                                                                Value="{DynamicResource DataGridHeaderBackground}"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource DataGridHeaderForeground}"/>
                                                                        <Setter Property="FontWeight"
                                                                                Value="Bold"/>
                                                                        <Setter Property="FontSize"
                                                                                Value="18"/>
                                                                        <Setter Property="Height"
                                                                                Value="40"/>
                                                                        <Setter Property="BorderBrush"
                                                                                Value="{DynamicResource GridHeaderSeperatorBrush}"/>
                                                                        <Setter Property="BorderThickness"
                                                                                Value="0,0,1,1"/>
                                                                        <Setter Property="HorizontalContentAlignment"
                                                                                Value="Left"/>
                                                                        <Setter Property="Padding"
                                                                                Value="10,0,0,0"/>
                                                                </Style>

                                                                <!-- Стиль для ячеек -->
                                                                <Style TargetType="DataGridCell">
                                                                        <Setter Property="Background"
                                                                                Value="{DynamicResource DataGridCellBackground}"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource DataGridCellForeground}"/>
                                                                        <Setter Property="BorderBrush"
                                                                                Value="Transparent"/>
                                                                        <Setter Property="VerticalAlignment"
                                                                                Value="Center"/>
                                                                        <Setter Property="Padding"
                                                                                Value="10,5,0,5"/>
                                                                        <Setter Property="FontSize"
                                                                                Value="18"/>
                                                                        <Style.Triggers>
                                                                                <Trigger Property="IsSelected"
                                                                                         Value="True">
                                                                                        <Setter Property="Background"
                                                                                                Value="{DynamicResource DataGridRowSelectedBackground}"/>
                                                                                        <Setter Property="Foreground"
                                                                                                Value="{DynamicResource DataGridCellSelectedForeground}"/>
                                                                                        <Setter Property="BorderBrush"
                                                                                                Value="{DynamicResource DataGridSelectionBorderBrush}"/>
                                                                                </Trigger>
                                                                        </Style.Triggers>
                                                                </Style>

                                                                <!-- Стиль для строк -->
                                                                <Style TargetType="DataGridRow">
                                                                        <Setter Property="Background"
                                                                                Value="{DynamicResource DataGridRowBackground}"/>
                                                                        <Setter Property="MinHeight"
                                                                                Value="35"/>
                                                                        <Style.Triggers>
                                                                                <Trigger Property="AlternationIndex"
                                                                                         Value="1">
                                                                                        <Setter Property="Background"
                                                                                                Value="{DynamicResource DataGridRowAltBackground}"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsSelected"
                                                                                         Value="True">
                                                                                        <Setter Property="Background"
                                                                                                Value="{DynamicResource DataGridRowSelectedBackground}"/>
                                                                                </Trigger>
                                                                        </Style.Triggers>
                                                                </Style>
                                                        </DataGrid.Resources>
                                                        <!-- Hz, ne rabotaet chet -->
                                                        <DataGrid.Columns>

                                                                <!-- В DataGrid.Columns, перед колонкой NAME -->
                                                                <DataGridTemplateColumn Header=""
                                                                                        Visibility="{Binding Data.IsCompactMode, 
                 Source={StaticResource Proxy}, 
                 Converter={StaticResource InverseBoolToVisConverter}}"
                                                                                        Width="75">
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                        <Border Width="75"
                                                                                                Height="75"
                                                                                                CornerRadius="4"
                                                                                                BorderThickness="1"
                                                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                                                Background="{DynamicResource CentralPanelCardBackground}">
                                                                                                <Grid>
                                                                                                        <Path Data="{DynamicResource default_coverGeometry}"
                                                                                                              Fill="{DynamicResource AccentBrush}"
                                                                                                              Stretch="Uniform"
                                                                                                              Margin="5"
                                                                                                              HorizontalAlignment="Center"
                                                                                                              VerticalAlignment="Center"/>
                                                                                                        <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}"
                                                                                                               Stretch="UniformToFill"
                                                                                                               HorizontalAlignment="Center"
                                                                                                               VerticalAlignment="Center">
                                                                                                                <Image.Style>
                                                                                                                        <Style TargetType="Image">
                                                                                                                                <Setter Property="Visibility"
                                                                                                                                        Value="Visible"/>
                                                                                                                                <Style.Triggers>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                                                     Value="{x:Null}">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Collapsed"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                                                     Value="0">
                                                                                                                                                <Setter Property="Visibility"
                                                                                                                                                        Value="Collapsed"/>
                                                                                                                                        </DataTrigger>
                                                                                                                                </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                </Image.Style>
                                                                                                        </Image>
                                                                                                </Grid>
                                                                                        </Border>
                                                                                </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>

                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="TITLE"
                                                                                    Binding="{Binding Name}"
                                                                                    Width="3*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource DataGridCellForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                        <Setter Property="TextBlock.VerticalAlignment"
                                                                                                Value="Center"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>

                                                                <DataGridTextColumn Header="ARTIST"
                                                                                    Binding="{Binding Executor}"
                                                                                    Width="2*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource CentralPanelSecondaryForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                        <Setter Property="TextBlock.VerticalAlignment"
                                                                                                Value="Center"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>

                                                                <DataGridTextColumn Header="ALBUM"
                                                                                    Binding="{Binding Album}"
                                                                                    Width="2*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource CentralPanelSecondaryForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                        <Setter Property="TextBlock.VerticalAlignment"
                                                                                                Value="Center"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>

                                                                <DataGridTextColumn Header="DURATION"
                                                                                    Binding="{Binding Duration}"
                                                                                    Width="1*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                        <Setter Property="TextBlock.VerticalAlignment"
                                                                                                Value="Center"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>

                                                                <DataGridTextColumn Header="BITRATE"
                                                                                    Binding="{Binding Bitrate}"
                                                                                    Visibility="{Binding Data.IsCompactMode, 
                                                                                        Source={StaticResource Proxy}, 
                                                                                        Converter={StaticResource InverseBoolToVisConverter}}"
                                                                                    Width="1*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                        <Setter Property="TextBlock.VerticalAlignment"
                                                                                                Value="Center"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                                <DataGridTextColumn Header="GENRE"
                                                                                    Binding="{Binding Genre}"
                                                                                    Visibility="{Binding Data.IsCompactMode, 
                                                                                                Source={StaticResource Proxy}, 
                                                                                                Converter={StaticResource InverseBoolToVisConverter}}"
                                                                                    Width="1*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                                <DataGridTextColumn Header="DATE ADDED"
                                                                                    Binding="{Binding AddedDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}"
                                                                                    Visibility="{Binding Data.IsCompactMode, Source={StaticResource Proxy}, Converter={StaticResource InverseBoolToVisConverter}}"
                                                                                    Width="1*">
                                                                        <DataGridTextColumn.ElementStyle>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="TextBlock.Foreground"
                                                                                                Value="{DynamicResource CentralPanelMutedForeground}"/>
                                                                                        <Setter Property="TextBlock.Margin"
                                                                                                Value="10,0,0,0"/>
                                                                                </Style>
                                                                        </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                        </DataGrid.Columns>
                                                </DataGrid>
                                                <Grid x:Name="LyricsOverlay"
                                                      Visibility="Collapsed"
                                                      Background="{DynamicResource TertiaryBackgroundBrush}">

                                                        <ListBox x:Name="LyricsListBox"
                                                                 Margin="50,20"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 VerticalAlignment="Stretch"
                                                                 HorizontalContentAlignment="Center"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                                 VirtualizingStackPanel.IsVirtualizing="False"
                                                                 PreviewKeyDown="LyricsListBox_PreviewKeyDown"
                                                                 MouseWheel="LyricsListBox_MouseWheel">

                                                                <ListBox.ItemContainerStyle>
                                                                        <Style TargetType="ListBoxItem">
                                                                                <Setter Property="Template">
                                                                                        <Setter.Value>
                                                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                                                        <ContentPresenter/>
                                                                                                </ControlTemplate>
                                                                                        </Setter.Value>
                                                                                </Setter>
                                                                        </Style>
                                                                </ListBox.ItemContainerStyle>

                                                                <ListBox.ItemTemplate>
                                                                        <DataTemplate>
                                                                                <TextBlock Text="{Binding Text}"
                                                                                           FontSize="32"
                                                                                           TextAlignment="Center"
                                                                                           Margin="0,15"
                                                                                           TextWrapping="Wrap">
                                                                                        <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                        <Setter Property="Foreground"
                                                                                                                Value="Gray"/>
                                                                                                        <Setter Property="Opacity"
                                                                                                                Value="0.6"/>
                                                                                                        <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsActive}"
                                                                                                                             Value="True">
                                                                                                                        <Setter Property="Foreground"
                                                                                                                                Value="White"/>
                                                                                                                        <Setter Property="Opacity"
                                                                                                                                Value="1.0"/>
                                                                                                                        <Setter Property="FontWeight"
                                                                                                                                Value="Bold"/>
                                                                                                                </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                </Style>
                                                                                        </TextBlock.Style>
                                                                                </TextBlock>
                                                                        </DataTemplate>
                                                                </ListBox.ItemTemplate>
                                                        </ListBox>
                                                </Grid>
                                        </Grid>
                                </Grid>

                                <!-- Правая колонка - NOW PLAYING -->
                                <Border Grid.Column="2"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource TertiaryBackgroundBrush}"
                                        BorderThickness="1,0,0,0"
                                        BorderBrush="{DynamicResource BorderBrush}">

                                        <Grid>

                                                <Grid x:Name="NowPlayingLoadingPlaceholder"
                                                      Visibility="Collapsed"
                                                      Margin="20">
                                                        <StackPanel VerticalAlignment="Top">
                                                                <Border Height="275"
                                                                        Width="275"
                                                                        CornerRadius="8"
                                                                        Background="#333333"
                                                                        Opacity="0.5"
                                                                        Margin="0,15"
                                                                        HorizontalAlignment="Center"/>
                                                                <Border Height="30"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"
                                                                        Margin="0,15"/>
                                                                <Border Height="25"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"
                                                                        Margin="0,15"/>
                                                                <Border Height="20"
                                                                        CornerRadius="4"
                                                                        Background="#333333"
                                                                        Opacity="0.5"
                                                                        Margin="0,15"/>
                                                        </StackPanel>
                                                </Grid>

                                                <StackPanel VerticalAlignment="Top"
                                                            x:Name="NowPlayingPanel">
                                                        <TextBlock x:Name="NowPlaying"
                                                                   Text=""
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   FontSize="20"
                                                                   FontWeight="Bold"
                                                                   Margin="0,0,0,20"/>

                                                        <Border x:Name="CurrentTrackImage1"
                                                                CornerRadius="8"
                                                                ClipToBounds="True"
                                                                Height="275"
                                                                Width="275"
                                                                Background="{DynamicResource CentralPanelCardBackground}"
                                                                BorderBrush="{DynamicResource CentralPanelCardBorderBrush}"
                                                                BorderThickness="1"
                                                                Margin="0,0,0,10">
                                                                <Image x:Name="CurrentTrackImage"/>
                                                        </Border>

                                                        <TextBlock x:Name="CurrentTrackName"
                                                                   Text=""
                                                                   FontSize="22"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource CentralPanelHighlightForeground}"
                                                                   TextWrapping="Wrap"/>

                                                        <TextBlock x:Name="CurrentTrackExecutor"
                                                                   Text=""
                                                                   FontSize="20"
                                                                   Foreground="{DynamicResource CentralPanelSecondaryForeground}"
                                                                   Margin="0,5"/>

                                                        <TextBlock x:Name="CurrentTrackAlbum"
                                                                   Text=""
                                                                   FontSize="20"
                                                                   Foreground="{DynamicResource CentralPanelSecondaryForeground}"/>

                                                        <TextBlock x:Name="CurrentTrackData"
                                                                   Text=""
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource CentralPanelMutedForeground}"
                                                                   Margin="0,20,0,0"/>

                                                        <TextBlock x:Name="CurrentTrackExtension"
                                                                   Text=""
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource CentralPanelMutedForeground}"/>

                                                        <TextBlock x:Name="CurrentTrackYear"
                                                                   Text=""
                                                                   FontSize="16"
                                                                   Foreground="{DynamicResource CentralPanelMutedForeground}"/>

                                                        <StackPanel x:Name="NextTrackPanel"
                                                                    Margin="0,20,0,0">
                                                                <TextBlock x:Name="NextTrack"
                                                                           Text=""
                                                                           FontSize="12"
                                                                           Foreground="{DynamicResource CentralPanelSecondaryForeground}"
                                                                           FontWeight="Bold"/>
                                                                <TextBlock x:Name="NextTrackName"
                                                                           Text=""
                                                                           FontSize="14"
                                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                                           TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <Grid>
                                                                <vis:SpectrumControl x:Name="SpectrumViewer"
                                                                                     Height="150"
                                                                                     VerticalAlignment="Bottom"
                                                                                     HorizontalAlignment="Stretch"
                                                                                     BorderThickness="2"/>
                                                        </Grid>
                                                </StackPanel>
                                        </Grid>
                                </Border>
                        </Grid>
                </DockPanel>
                <dialogs:ModernNotice x:Name="MyToast"
                                      Grid.Row="1"
                                      VerticalAlignment="Bottom"
                                      HorizontalAlignment="Center"
                                      Panel.ZIndex="9999"/>
        </Grid>
</Window>