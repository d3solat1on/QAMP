<Window x:Class="QAMP.Windows.SettingsAudio"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QAMP.Windows"
        xmlns:converters="clr-namespace:QAMP.Converters"
        Title="Настройки звука"
        Width="1000"
        Height="800"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <Style x:Key="EqSliderThumbStyle"
               TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentBrush}"
                                Width="8"
                                Height="16"
                                CornerRadius="4"
                                RenderOptions.EdgeMode="Aliased">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="6"
                                                  ShadowDepth="1"
                                                  Opacity="0.8"/>
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomSliderStyle"
               TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border x:Name="TrackBackground"
                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                    Width="4"
                                    HorizontalAlignment="Center"
                                    CornerRadius="2"
                                    Opacity="0.6"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EqSliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            CornerRadius="5"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{DynamicResource SecondaryBackgroundBrush}">
                <TextBlock Text="Настройки звука"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundBrush}"/>
                <Button x:Name="BtnClose"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CloseButton_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                    <Path Data="{StaticResource closeGeometry}"
                          Fill="{DynamicResource AccentBrush}"
                          Stretch="Uniform"
                          Width="18"
                          Height="18"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20">
                    <GroupBox Header="Эквалайзер"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Canvas x:Name="EqGraphCanvas"
                                    Grid.Row="0"
                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                    Margin="10"/>

                            <StackPanel Grid.Row="1">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,5,0,10">
                                    <ComboBox x:Name="PresetComboBox"
                                              Width="180"
                                              Margin="0,0,10,0"
                                              SelectionChanged="PresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Пользовательский"/>
                                        <ComboBoxItem Content="Bass Boost"/>
                                        <ComboBoxItem Content="Rock"/>
                                        <ComboBoxItem Content="Classical"/>
                                        <ComboBoxItem Content="Pop"/>
                                        <ComboBoxItem Content="Lo-Fi"/>
                                        <ComboBoxItem Content="Electronic"/>
                                        <ComboBoxItem Content="Vocal"/>
                                        <ComboBoxItem Content="Metal"/>
                                        <ComboBoxItem Content="808"/>
                                    </ComboBox>

                                    <Button Style="{StaticResource ModernPlayerButton}"
                                            Content="Сбросить"
                                            Padding="10,5"
                                            Click="ResetEq_Click"
                                            BorderBrush="{DynamicResource BorderBrush}"/>
                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                              HorizontalScrollBarVisibility="Auto"
                                              Margin="10,0">
                                    <ItemsControl x:Name="EqItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Width="50"
                                                            Margin="7,0">
                                                    <TextBlock Text="{Binding Gain, StringFormat={}{0:0}}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               Margin="0,0,0,3"/>

                                                    <Slider Orientation="Vertical"
                                                            Height="160"
                                                            Minimum="-12"
                                                            Maximum="12"
                                                            Value="{Binding Gain, Mode=TwoWay}"
                                                            TickFrequency="1"
                                                            IsSnapToTickEnabled="True"
                                                            ValueChanged="EqSlider_ValueChanged"
                                                            HorizontalAlignment="Center"
                                                            Style="{StaticResource CustomSliderStyle}"/>

                                                    <TextBlock Text="{Binding Frequency}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Margin="0,5,0,0"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Эффекты и обработка звука"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,20">
                        <StackPanel Margin="10"
                                    Orientation="Vertical">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10">
                                <CheckBox x:Name="ReverbEnabled"
                                          Content="Реверберация"
                                          Foreground="{DynamicResource ForegroundBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Checked="AudioProcessingSettingChanged"
                                          Unchecked="AudioProcessingSettingChanged"/>
                                <TextBlock Text="Уровень:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,5,0"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <Slider x:Name="ReverbLevelSlider"
                                        Minimum="0"
                                        Maximum="100"
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        ValueChanged="ReverbLevelSlider_ValueChanged"/>
                                <TextBlock x:Name="ReverbLevelText"
                                           Text="50%"
                                           VerticalAlignment="Center"
                                           Width="40"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10">
                                <CheckBox x:Name="EchoEnabled"
                                          Content="Эхо / Задержка"
                                          Foreground="{DynamicResource ForegroundBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Checked="AudioProcessingSettingChanged"
                                          Unchecked="AudioProcessingSettingChanged"/>
                                <TextBlock Text="Задержка:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,5,0"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <Slider x:Name="EchoDelaySlider"
                                        Minimum="0"
                                        Maximum="1000"
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        ValueChanged="EchoDelaySlider_ValueChanged"/>
                                <TextBlock x:Name="EchoDelayText"
                                           Text="300 ms"
                                           VerticalAlignment="Center"
                                           Width="60"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10">
                                <CheckBox x:Name="VocalEnhancementEnabled"
                                          Content="Усиление вокала"
                                          Foreground="{DynamicResource ForegroundBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,15,0"
                                          Checked="AudioProcessingSettingChanged"
                                          Unchecked="AudioProcessingSettingChanged"/>
                                <CheckBox x:Name="LoudnessEnabled"
                                          Content="Тонкомпенсация"
                                          Foreground="{DynamicResource ForegroundBrush}"
                                          VerticalAlignment="Center"
                                          Checked="AudioProcessingSettingChanged"
                                          Unchecked="AudioProcessingSettingChanged"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10">
                                <TextBlock Text="Tempo / Speed:"
                                           VerticalAlignment="Center"
                                           Width="80"
                                           Margin="0,0,5,0"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <Slider x:Name="TempoSlider"
                                        Minimum="0.5"
                                        Maximum="2.0"
                                        TickFrequency="0.05"
                                        Width="200"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        ValueChanged="TempoPitchSlider_ValueChanged"/>
                                <TextBlock x:Name="TempoText"
                                           Text="1.00x"
                                           VerticalAlignment="Center"
                                           Width="40"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10">
                                <TextBlock Text="Pitch:"
                                           VerticalAlignment="Center"
                                           Width="80"
                                           Margin="0,0,5,0"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <Slider x:Name="PitchSlider"
                                        Minimum="0.5"
                                        Maximum="2.0"
                                        TickFrequency="0.05"
                                        Width="200"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        ValueChanged="TempoPitchSlider_ValueChanged"/>
                                <TextBlock x:Name="PitchText"
                                           Text="1.00x"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Динамика и баланс"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,20">
                        <StackPanel Margin="10"
                                    Orientation="Vertical">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,10">
                                <CheckBox x:Name="CompressorEnabled"
                                          Content="Компрессор / Лимитер"
                                          Foreground="{DynamicResource ForegroundBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Checked="AudioProcessingSettingChanged"
                                          Unchecked="AudioProcessingSettingChanged"/>
                                <TextBlock Text="Порог:"
                                           VerticalAlignment="Center"
                                           Width="50"
                                           Margin="0,0,5,0"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <Slider x:Name="CompressorThresholdSlider"
                                        Minimum="0"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        Width="150"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        ValueChanged="CompressorThresholdSlider_ValueChanged"/>
                                <TextBlock x:Name="CompressorThresholdText"
                                           Text="0.50"
                                           VerticalAlignment="Center"
                                           Width="40"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Баланс:"
                                           VerticalAlignment="Center"
                                           Width="50"
                                           Margin="0,0,5,0"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <Slider x:Name="BalanceSlider"
                                        Minimum="-1"
                                        Maximum="1"
                                        TickFrequency="0.05"
                                        Width="300"
                                        VerticalAlignment="Center"
                                        Margin="0,0,5,0"
                                        ValueChanged="BalanceSlider_ValueChanged"/>
                                <TextBlock x:Name="BalanceText"
                                           Text="0.00"
                                           VerticalAlignment="Center"
                                           Width="40"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Вывод"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Margin="0,0,0,20">
                        <StackPanel Margin="10"
                                    Orientation="Vertical">
                            <TextBlock Text="Выберите устройство:"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       Margin="0,0,0,5"/>
                            <ComboBox x:Name="OutputDeviceComboBox"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      SelectionChanged="OutputDeviceComboBox_SelectionChanged"
                                      Width="450"
                                      Height="30"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource SecondaryBackgroundBrush}">
                <Button Content="Закрыть"
                        Style="{StaticResource ModernPlayerButton}"
                        Margin="5,0,0,0"
                        Width="100"
                        Height="35"
                        Click="CloseButton_Click"
                        BorderBrush="{DynamicResource BorderBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>