<Window x:Class="QAMP.Windows.Statistics"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QAMP.Windows"
        xmlns:converters="clr-namespace:QAMP.Converters"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="1000"
        Height="800"
        Title="Ваша статистика"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- <converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter"/> -->
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{DynamicResource SecondaryBackgroundBrush}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="Статистика QAMP"
                               Foreground="{DynamicResource ForegroundBrush}"
                               FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="BtnClose"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click">
                        <Path Data="{StaticResource closeGeometry}"
                              Fill="{DynamicResource AccentBrush}"
                              Stretch="Uniform"
                              Width="18"
                              Height="18"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Статистика"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>
                    <GroupBox Grid.Row="1"
                              Header="Общая статистика"
                              Margin="0,0,0,20">
                        <StackPanel Margin="10">
                            <TextBlock x:Name="MostListenedTrackText"
                                       Text="Самая прослушиваемая композиция: "
                                       Margin="0,0,0,10"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock x:Name="MostListenedArtistText"
                                       Text="Самый прослушиваемый исполнитель: "
                                       Margin="0,0,0,10"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock x:Name="TracksWithoutListening"
                                       Text="Треки без прослушивания"
                                       Margin="0,0,0,10"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="2"
                              Header="Рекорды коллекции"
                              Margin="0,0,0,15">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Самый длинный трек:"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LongestTrackText"
                                       Margin="10,0,0,5"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1"
                                       Text="Самый короткий трек:"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       x:Name="ShortestTrackText"
                                       Margin="10,0,0,5"/>

                            <TextBlock Grid.Row="2"
                                       Text="Трек с самым высокий битрейтом:"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       x:Name="HighestBitrateText"
                                       Margin="10,0,0,5"/>


                            <TextBlock Grid.Row="3"
                                       Text="Общая длина библиотеки:"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       x:Name="TotalLibrarySizeText"
                                       Margin="10,0,0,5"/>
                            <TextBlock Grid.Row="4"
                                       Text="Вес библиотеки:"
                                       FontWeight="SemiBold"
                                       Margin="10,0,0,5"/>
                            <TextBlock Grid.Row="4"
                                       Grid.Column="1"
                                       x:Name="TotalLibraryWeightText"
                                       Margin="10,0,0,5"/>
                        </Grid>
                    </GroupBox>
                    <GroupBox Grid.Row="3"
                              Header="Количество плейлистов и треков"
                              Margin="0,0,0,15">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Количество плейлистов:"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       x:Name="PlaylistCountText"
                                       Margin="10,0,0,5"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Количество треков:"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       x:Name="TrackCountText"
                                       Margin="10,0,0,5"/>
                        </Grid>
                    </GroupBox>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>   