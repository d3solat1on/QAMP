<Window x:Class="QAMP.Windows.ShowTrackInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QAMP.Windows"
        xmlns:converters="clr-namespace:QAMP.Converters"
        xmlns:dialogs="clr-namespace:QAMP.Dialogs"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="1000"
        Height="800"
        Title="{DynamicResource LngInfoTrack}"
        WindowStartupLocation="CenterOwner"
        MouseDown="Window_MouseDown">

        <Window.Resources>
                <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
                <converters:LargeTrackImageConverter x:Key="LargeTrackImageConverter"/>
                <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

                <Style TargetType="ScrollViewer">
                        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                                Value="Disabled"/>
                        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                                Value="Auto"/>
                        <Setter Property="Background"
                                Value="Transparent"/>
                </Style>
                <Style x:Key="EditableTextStyle"
                       TargetType="TextBox">
                        <Setter Property="Background"
                                Value="Transparent"/>
                        <Setter Property="Foreground"
                                Value="{DynamicResource TextBrush}"/>
                        <Setter Property="BorderThickness"
                                Value="0"/>
                        <Setter Property="Padding"
                                Value="2"/>
                        <Setter Property="CaretBrush"
                                Value="{DynamicResource BorderBrush}"/>
                        <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=EditModeButton, Path=IsChecked}"
                                             Value="False">
                                        <Setter Property="IsReadOnly"
                                                Value="True"/>
                                        <Setter Property="Focusable"
                                                Value="False"/>
                                        <Setter Property="Cursor"
                                                Value="Arrow"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementName=EditModeButton, Path=IsChecked}"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                        <Setter Property="BorderThickness"
                                                Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush"
                                                Value="{DynamicResource BorderBrush}"/>
                                </DataTrigger>
                        </Style.Triggers>
                </Style>
        </Window.Resources>

        <Grid>
                <Border Background="{DynamicResource DataGridHeaderBackground}"
                        CornerRadius="5"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1">
                        <Grid Margin="0">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="20,15,20,0"
                                      Height="40">
                                        <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{DynamicResource LngInfoTrack}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource ModernPlayerButton}"
                                                Content="{DynamicResource LngSaveButton}"
                                                Click="Save_Click"
                                                VerticalAlignment="Center"
                                                Width="100"
                                                Height="30"
                                                Margin="0,0,10,0"
                                                Visibility="{Binding ElementName=EditModeButton, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <ToggleButton x:Name="EditModeButton"
                                                      Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      Width="30"
                                                      Height="30"
                                                      Margin="0,0,10,0"
                                                      ToolTip="{DynamicResource LngEditTags}"
                                                      Background="{DynamicResource AccentBrush}">
                                                <Path Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25M20.71,7.04C21.1,6.65 21.1,6.02 20.71,5.63L18.37,3.29C17.98,2.9 17.35,2.9 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04Z"
                                                      Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                                                      Stretch="Uniform"
                                                      Width="14"
                                                      Height="14"/>
                                                <ToggleButton.Resources>
                                                        <Style TargetType="Border">
                                                                <Setter Property="CornerRadius"
                                                                        Value="2"/>
                                                        </Style>
                                                </ToggleButton.Resources>
                                        </ToggleButton>
                                        <Button Grid.Column="3"
                                                Content="✕"
                                                Click="Close_Click"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource CloseButtonStyle}"
                                                Background="{DynamicResource AccentBrush}"
                                                Width="30"
                                                Height="30">
                                                <Button.Resources>
                                                        <Style TargetType="Border">
                                                                <Setter Property="CornerRadius"
                                                                        Value="2"/>
                                                        </Style>
                                                </Button.Resources>
                                        </Button>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              Margin="20">
                                        <Grid>
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="300"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                        <Border CornerRadius="10"
                                                                ClipToBounds="True"
                                                                Height="300"
                                                                Width="300"
                                                                Background="{DynamicResource CentralPanelCardBackground}"
                                                                Cursor="Hand"
                                                                MouseLeftButtonDown="ChangeCover_Click">
                                                                <Grid>
                                                                        <Path Data="{DynamicResource default_coverGeometry}"
                                                                              Fill="{DynamicResource AccentBrush}"
                                                                              Stretch="Uniform"
                                                                              HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                                        <Image Source="{Binding CoverImage, Converter={StaticResource LargeTrackImageConverter}}"
                                                                               Stretch="UniformToFill"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center">
                                                                                <Image.Style>
                                                                                        <Style TargetType="Image">
                                                                                                <Setter Property="Visibility"
                                                                                                        Value="Visible"/>
                                                                                                <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding CoverImage}"
                                                                                                                     Value="{x:Null}">
                                                                                                                <Setter Property="Visibility"
                                                                                                                        Value="Collapsed"/>
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding CoverImage.Length}"
                                                                                                                     Value="0">
                                                                                                                <Setter Property="Visibility"
                                                                                                                        Value="Collapsed"/>
                                                                                                        </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                        </Style>
                                                                                </Image.Style>
                                                                        </Image>
                                                                </Grid>
                                                        </Border>

                                                        <TextBlock Text="{Binding Duration}"
                                                                   HorizontalAlignment="Center"
                                                                   FontSize="24"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   Margin="0,15,0,0"/>
                                                        <Button Style="{StaticResource ModernPlayerButton}"
                                                                Content="{DynamicResource LngExtractCover}"
                                                                Click="ExtractCover_Click"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,10,0,0"
                                                                Background="{DynamicResource AccentBrush}">
                                                        </Button>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Margin="25,0,0,0">
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource EditableTextStyle}"
                                                                 FontSize="28"
                                                                 FontWeight="Bold"
                                                                 Foreground="{DynamicResource TextBrush}"
                                                                 TextWrapping="Wrap"
                                                                 Margin="0,0,0,5"/>

                                                        <TextBox Text="{Binding Executor, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource EditableTextStyle}"
                                                                 FontSize="18"
                                                                 Foreground="{DynamicResource AccentBrush}"
                                                                 Margin="0,0,0,20"/>

                                                        <Grid Margin="0,0,0,15">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngAlbum}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,5"/>
                                                                <TextBox Grid.Row="0"
                                                                         Grid.Column="1"
                                                                         Text="{Binding Album, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         Margin="0,5"
                                                                         TextWrapping="Wrap"/>

                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngAlbumArtist}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,5"/>
                                                                <TextBox Grid.Row="1"
                                                                         Grid.Column="1"
                                                                         Text="{Binding AlbumArtist, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         Margin="0,5"
                                                                         TextWrapping="Wrap"/>

                                                                <TextBlock Grid.Row="2"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngGenre}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,5"/>
                                                                <TextBox Grid.Row="2"
                                                                         Grid.Column="1"
                                                                         Text="{Binding Genre, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         Margin="0,5"/>

                                                                <TextBlock Grid.Row="3"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngYear}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,5"/>
                                                                <TextBox Grid.Row="3"
                                                                         Grid.Column="1"
                                                                         Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         Margin="0,5"/>

                                                                <TextBlock Grid.Row="4"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngTrackNumber}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,5"/>
                                                                <TextBox Grid.Row="4"
                                                                         Grid.Column="1"
                                                                         Text="{Binding TrackNumber, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         Margin="0,5"/>

                                                                <TextBlock Grid.Row="5"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngComposer}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,5"/>
                                                                <TextBox Grid.Row="5"
                                                                         Grid.Column="1"
                                                                         Text="{Binding Composer, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         Margin="0,5"
                                                                         TextWrapping="Wrap"/>
                                                        </Grid>

                                                        <Separator Background="{DynamicResource BorderBrush}"
                                                                   Margin="0,10"/>

                                                        <TextBlock Text="{DynamicResource LngSettingsAudio}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>

                                                        <Grid Margin="0,0,0,15">
                                                                <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="100"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngBitrate}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="0"
                                                                           Grid.Column="1"
                                                                           Text="{Binding Bitrate, StringFormat='{}{0} kbps'}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>

                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngSampleRate}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="1"
                                                                           Text="{Binding SampleRate, StringFormat='{}{0} Hz'}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>

                                                                <TextBlock Grid.Row="2"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngChannels}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="2"
                                                                           Grid.Column="1"
                                                                           Text="{Binding Channels}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>

                                                                <TextBlock Grid.Row="3"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngBitsPerSample}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="3"
                                                                           Grid.Column="1"
                                                                           Text="{Binding BitsPerSample, StringFormat='{}{0} bit'}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>

                                                                <TextBlock Grid.Row="4"
                                                                           Grid.Column="0"
                                                                           Text="{DynamicResource LngDescription}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="4"
                                                                           Grid.Column="1"
                                                                           Text="{Binding Description}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="5"
                                                                           Grid.Column="0"
                                                                           Text="BPS:"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="5"
                                                                           Grid.Column="1"
                                                                           Text="{Binding BitsPerSample}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock Grid.Row="6"
                                                                           Grid.Column="0"
                                                                           Text="BPM:"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           Margin="0,3"/>
                                                                <TextBlock x:Name="BPMTextBlock"
                                                                           Grid.Row="6"
                                                                           Grid.Column="1"
                                                                           Text="{Binding BPM}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,3"/>
                                                                <Button Width="150"
                                                                        Height="25"
                                                                        Grid.Row="7"
                                                                        Grid.Column="1"
                                                                        Content="{DynamicResource LngDetectBPM}"
                                                                        Click="DetectBPM_Click"
                                                                        Background="{DynamicResource AccentBrush}"
                                                                        Style="{StaticResource ModernPlayerButton}"
                                                                        Margin="10,0,0,0"
                                                                        Visibility="{Binding ElementName=EditModeButton, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                        </Grid>
                                                        <Separator Background="#333"
                                                                   Margin="0,10"/>

                                                        <TextBlock Text="{DynamicResource LngComment}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>
                                                                   <!-- p1zdec че за хуйня со цветом -->
                                                        <Border Background="{DynamicResource DataGridRowSelectedBackground}"
                                                                CornerRadius="5"
                                                                Padding="10"
                                                                Margin="0,0,0,10">
                                                                <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{StaticResource EditableTextStyle}"
                                                                         Foreground="{DynamicResource TextBrush}"
                                                                         TextWrapping="Wrap"
                                                                         FontSize="12"
                                                                         MaxHeight="100"/>
                                                        </Border>

                                                        <Button Style="{StaticResource ModernPlayerButton}"
                                                                Content="{DynamicResource LngFindLyrics}"
                                                                Click="SearchLyrics_Click"
                                                                Visibility="{Binding ElementName=EditModeButton, Path=IsChecked, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Width="150"
                                                                Height="25"
                                                                Background="{DynamicResource AccentBrush}"
                                                                ToolTip="{DynamicResource LngAPILyrics}"
                                                                Margin="5">
                                                        </Button>
                                                        <TextBlock Text="{DynamicResource LngLyricsTrack}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>
                                                        <Border x:Name="LyricsBorder"
                                                                Background="{DynamicResource DataGridRowSelectedBackground}"
                                                                CornerRadius="5"
                                                                Padding="10"
                                                                Margin="0,0,0,10"
                                                                Cursor="Hand">
                                                                <ScrollViewer MaxHeight="150"
                                                                              PreviewMouseLeftButtonDown="LyricsBorder_MouseLeftButtonDown"
                                                                              VerticalScrollBarVisibility="Auto">
                                                                        <TextBox Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Style="{StaticResource EditableTextStyle}"
                                                                                 AcceptsReturn="True"
                                                                                 Foreground="{DynamicResource TextBrush}"
                                                                                 TextWrapping="Wrap"
                                                                                 FontSize="12"
                                                                                 FontFamily="Consolas"
                                                                                 AcceptsTab="True"/>
                                                                </ScrollViewer>
                                                        </Border>

                                                        <TextBlock Text="{DynamicResource LngPlayCountTrack}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>
                                                        <Border Background="{DynamicResource CentralPanelCardBackground}"
                                                                CornerRadius="5"
                                                                Padding="10">
                                                                <TextBlock x:Name="PlayCountTextBlock"
                                                                           Text="{Binding PlayCount}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="10"
                                                                           FontFamily="Consolas"/>
                                                        </Border>
                                                        <TextBlock Text="{DynamicResource LngSizeFile}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>
                                                        <Border Background="{DynamicResource CentralPanelCardBackground}"
                                                                CornerRadius="5"
                                                                Padding="10">
                                                                <TextBlock Text="{Binding Size, StringFormat='{}{0:F3} MB'}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="10"
                                                                           FontFamily="Consolas"/>
                                                        </Border>

                                                        <TextBlock Text="{DynamicResource LngExstensionFile}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>
                                                        <Border Background="{DynamicResource CentralPanelCardBackground}"
                                                                CornerRadius="5"
                                                                Padding="10">
                                                                <TextBlock x:Name="ExstensionFile"
                                                                           Text="{Binding DisplayExtension}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="10"
                                                                           FontFamily="Consolas"/>
                                                        </Border>
                                                        <TextBlock Text="{DynamicResource LngPathTrack}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Margin="0,10,0,5"/>
                                                        <Border Background="{DynamicResource CentralPanelCardBackground}"
                                                                CornerRadius="5"
                                                                Padding="10"
                                                                Cursor="Hand">
                                                                <TextBlock Text="{Binding Path}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Background="Transparent"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="10"
                                                                           FontFamily="Consolas"
                                                                           TextDecorations="Underline"
                                                                           MouseLeftButtonDown="PathTextBlock_MouseLeftButtonDown">
                                                                        <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                        <Setter Property="Cursor"
                                                                                                Value="Hand"/>
                                                                                        <Style.Triggers>
                                                                                                <Trigger Property="IsMouseOver"
                                                                                                         Value="True">
                                                                                                        <Setter Property="Foreground"
                                                                                                                Value="{DynamicResource TextBrush}"/>
                                                                                                </Trigger>
                                                                                        </Style.Triggers>
                                                                                </Style>
                                                                        </TextBlock.Style>
                                                                </TextBlock>
                                                        </Border>
                                                </StackPanel>
                                        </Grid>
                                </ScrollViewer>
                        </Grid>
                </Border>
                <dialogs:ModernNotice x:Name="TrackInfoToast"
                                      VerticalAlignment="Bottom"
                                      HorizontalAlignment="Center"
                                      Panel.ZIndex="9999"/>
        </Grid>
</Window>