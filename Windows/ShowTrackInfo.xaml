<Window x:Class="QAMP.Windows.ShowTrackInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QAMP.Windows"
        xmlns:converters="clr-namespace:QAMP.Converters"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Width="1000"
        Height="800"
        Title="Подробная информация"
        WindowStartupLocation="CenterOwner"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <converters:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
        <converters:LargeTrackImageConverter x:Key="LargeTrackImageConverter"/>

        <Style TargetType="ScrollViewer">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                    Value="Auto"/>
            <Setter Property="Background"
                    Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E"
            CornerRadius="20"
            BorderBrush="#333"
            BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                    Margin="20,15,20,0"
                    Height="40">
                <TextBlock Text="Подробная информация о треке"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <Button Content="✕"
                        Click="Close_Click"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource CloseButtonStyle}"
                        Width="30"
                        Height="30"/>
            </Grid>

            <ScrollViewer Grid.Row="1"
                    Margin="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Border CornerRadius="10"
                                ClipToBounds="True"
                                Height="300"
                                Width="300"
                                Background="#2D2D2D">
                            <Image Source="{Binding CoverImage, Converter={StaticResource LargeTrackImageConverter}}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source"
                                                Value="/Resources/default_cover.png"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoverImage}"
                                                    Value="{x:Null}">
                                                <Setter Property="Source"
                                                        Value="/Resources/default_cover.png"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Border>

                        <TextBlock Text="{Binding Duration}"
                                   HorizontalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#00CCFF"
                                   Margin="0,15,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                            Margin="25,0,0,0">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,5"/>

                        <TextBlock Text="{Binding Executor}"
                                   FontSize="18"
                                   Foreground="#00CCFF"
                                   Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                    Grid.Column="0"
                                    Text="Альбом:"
                                    Foreground="Gray"
                                    Margin="0,5"/>
                            <TextBlock Grid.Row="0"
                                    Grid.Column="1"
                                    Text="{Binding Album}"
                                    Foreground="White"
                                    Margin="0,5"
                                    TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="1"
                                    Grid.Column="0"
                                    Text="Альбом исполнитель:"
                                    Foreground="Gray"
                                    Margin="0,5"/>
                            <TextBlock Grid.Row="1"
                                    Grid.Column="1"
                                    Text="{Binding AlbumArtist}"
                                    Foreground="White"
                                    Margin="0,5"
                                    TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2"
                                    Grid.Column="0"
                                    Text="Жанр:"
                                    Foreground="Gray"
                                    Margin="0,5"/>
                            <TextBlock Grid.Row="2"
                                    Grid.Column="1"
                                    Text="{Binding Genre}"
                                    Foreground="White"
                                    Margin="0,5"/>

                            <TextBlock Grid.Row="3"
                                    Grid.Column="0"
                                    Text="Год:"
                                    Foreground="Gray"
                                    Margin="0,5"/>
                            <TextBlock Grid.Row="3"
                                    Grid.Column="1"
                                    Text="{Binding Year}"
                                    Foreground="White"
                                    Margin="0,5"/>

                            <TextBlock Grid.Row="4"
                                    Grid.Column="0"
                                    Text="Трек №:"
                                    Foreground="Gray"
                                    Margin="0,5"/>
                            <TextBlock Grid.Row="4"
                                    Grid.Column="1"
                                    Text="{Binding TrackNumber}"
                                    Foreground="White"
                                    Margin="0,5"/>

                            <TextBlock Grid.Row="5"
                                    Grid.Column="0"
                                    Text="Композитор:"
                                    Foreground="Gray"
                                    Margin="0,5"/>
                            <TextBlock Grid.Row="5"
                                    Grid.Column="1"
                                    Text="{Binding Composer}"
                                    Foreground="White"
                                    Margin="0,5"
                                    TextWrapping="Wrap"/>
                        </Grid>

                        <Separator Background="#333"
                                Margin="0,10"/>

                        <TextBlock Text="Параметры аудио"
                                   FontWeight="Bold"
                                   Foreground="Gray"
                                   Margin="0,10,0,5"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                    Grid.Column="0"
                                    Text="Битрейт:"
                                    Foreground="Gray"
                                    Margin="0,3"/>
                            <TextBlock Grid.Row="0"
                                    Grid.Column="1"
                                    Text="{Binding Bitrate, StringFormat='{}{0} kbps'}"
                                    Foreground="White"
                                    Margin="0,3"/>

                            <TextBlock Grid.Row="1"
                                    Grid.Column="0"
                                    Text="Частота:"
                                    Foreground="Gray"
                                    Margin="0,3"/>
                            <TextBlock Grid.Row="1"
                                    Grid.Column="1"
                                    Text="{Binding SampleRate, StringFormat='{}{0} Hz'}"
                                    Foreground="White"
                                    Margin="0,3"/>

                            <TextBlock Grid.Row="2"
                                    Grid.Column="0"
                                    Text="Каналы:"
                                    Foreground="Gray"
                                    Margin="0,3"/>
                            <TextBlock Grid.Row="2"
                                    Grid.Column="1"
                                    Text="{Binding Channels}"
                                    Foreground="White"
                                    Margin="0,3"/>

                            <TextBlock Grid.Row="3"
                                    Grid.Column="0"
                                    Text="Разрядность:"
                                    Foreground="Gray"
                                    Margin="0,3"/>
                            <TextBlock Grid.Row="3"
                                    Grid.Column="1"
                                    Text="{Binding BitsPerSample, StringFormat='{}{0} bit'}"
                                    Foreground="White"
                                    Margin="0,3"/>

                            <TextBlock Grid.Row="4"
                                    Grid.Column="0"
                                    Text="Кодек:"
                                    Foreground="Gray"
                                    Margin="0,3"/>
                            <TextBlock Grid.Row="4"
                                    Grid.Column="1"
                                    Text="{Binding Description}"
                                    Foreground="White"
                                    Margin="0,3"/>
                        </Grid>

                        <Separator Background="#333"
                                Margin="0,10"/>

                        <TextBlock Text="Комментарий"
                                   FontWeight="Bold"
                                   Foreground="Gray"
                                   Margin="0,10,0,5"/>
                        <Border Background="#2D2D2D"
                                CornerRadius="5"
                                Padding="10"
                                Margin="0,0,0,10">
                            <TextBlock Text="{Binding Comment}"
                                       Foreground="#CCCCCC"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       MaxHeight="100"/>
                        </Border>

                        <TextBlock Text="Текст песни"
                                   FontWeight="Bold"
                                   Foreground="Gray"
                                   Margin="0,10,0,5"/>
                        <Border Background="#2D2D2D"
                                CornerRadius="5"
                                Padding="10"
                                Margin="0,0,0,10">
                            <ScrollViewer MaxHeight="150"
                                    VerticalScrollBarVisibility="Auto">
                                <TextBlock Text="{Binding Lyrics}"
                                           Foreground="#CCCCCC"
                                           TextWrapping="Wrap"
                                           FontSize="12"
                                           FontFamily="Consolas"/>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Text="Путь к файлу"
                                   FontWeight="Bold"
                                   Foreground="Gray"
                                   Margin="0,10,0,5"/>
                        <Border Background="#2D2D2D"
                                CornerRadius="5"
                                Padding="10"
                                Cursor="Hand">
                            <TextBlock Text="{Binding Path}"
                                       Foreground="#00CCFF"
                                       TextWrapping="Wrap"
                                       FontSize="10"
                                       FontFamily="Consolas"
                                       TextDecorations="Underline">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor"
                                                Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                    Value="True">
                                                <Setter Property="Foreground"
                                                        Value="#33CCFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>