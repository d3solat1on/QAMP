<Window x:Class="QAMP.Windows.LyricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogs="clr-namespace:QAMP.Dialogs"
        Title="Lyrics Editor"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            CornerRadius="{DynamicResource AppCornerRadius}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,20">
                <TextBlock Text="{Binding Name}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="{Binding Executor}"
                           FontSize="18"
                           Foreground="{DynamicResource AccentBrush}"/>
            </StackPanel>

            <TextBox Grid.Row="1"
                     x:Name="FullLyricsEditor"
                     Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="20"
                     Foreground="{DynamicResource ForegroundBrush}"
                     Background="Transparent"
                     BorderThickness="0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     CaretBrush="{DynamicResource AccentBrush}"
                     FontFamily="Consolas"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="CloseButton"
                        Style="{StaticResource ModernPlayerButton}"
                        Content="{DynamicResource LngClose}"
                        Click="Close_Click"
                        Width="100"
                        Margin="0,0,10,0">
                </Button>
                <Button x:Name="SaveButton"
                        Style="{StaticResource ModernPlayerButton}"
                        Content="{DynamicResource LngSaveButton}"
                        Click="Save_Click"
                        Width="100">
                </Button>
            </StackPanel>
            <dialogs:ModernNotice x:Name="TrackInfoToast"
                                  VerticalAlignment="Bottom"
                                  HorizontalAlignment="Center"
                                  Panel.ZIndex="9999"/>
        </Grid>
    </Border>
</Window>