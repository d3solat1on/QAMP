<Window x:Class="QAMP.Windows.LyricsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lyrics Editor"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="#121212"
            CornerRadius="20"
            BorderBrush="#333"
            BorderThickness="1">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,20">
                <TextBlock Text="{Binding Name}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="{Binding Executor}"
                           FontSize="18"
                           Foreground="#00CCFF"/>
            </StackPanel>

            <TextBox Grid.Row="1"
                     x:Name="FullLyricsEditor"
                     Text="{Binding Lyrics, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="20"
                     Foreground="#E3E3E3"
                     Background="Transparent"
                     BorderThickness="0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     CaretBrush="#00CCFF"
                     FontFamily="Consolas"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="Закрыть"
                        Background="{DynamicResource AccentBrush}"
                        Click="Close_Click"
                        Width="100"
                        Margin="0,0,10,0"/>
                <Button Content="Сохранить"
                        Background="{DynamicResource AccentBrush}"
                        Click="Save_Click"
                        Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>