<Window x:Class="QAMP.Windows.OSDWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QAMP.Windows"
        xmlns:converters="clr-namespace:QAMP.Converters"
        Title="OSD"
        Height="50"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False">
    <Border x:Name="MainBorder"
            Background="#E6111111"
            CornerRadius="5"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1.5"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10">
        <StackPanel Orientation="Horizontal"
                    Margin="15,5">
            <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z"
                  Fill="{DynamicResource AccentBrush}"
                  Width="16"
                  Height="16"
                  Stretch="Uniform"
                  Margin="0,0,10,0"
                  VerticalAlignment="Center"/>

            <TextBlock x:Name="ExecutorText"
                       Text="Artist"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Text=" — "
                       Foreground="White"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="NameText"
                       Text="Track Title"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>