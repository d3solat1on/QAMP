<Window x:Class="QAMP.Windows.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP"
        xmlns:converters="clr-namespace:QAMP.Converters"
        xmlns:viewModels="clr-namespace:QAMP.ViewModels"
        xmlns:services="clr-namespace:QAMP.Services"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Настройки QAMP"
        Width="1600"
        Height="Auto"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="EqSliderThumbStyle"
               TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentBrush}"
                                Width="8"
                                Height="16"
                                CornerRadius="4"
                                RenderOptions.EdgeMode="Aliased">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="6"
                                                  ShadowDepth="1"
                                                  Opacity="0.8"/>
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomSliderStyle"
               TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border x:Name="TrackBackground"
                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                    Width="4"
                                    HorizontalAlignment="Center"
                                    CornerRadius="2"
                                    Opacity="0.6"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EqSliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Строка заголовка -->
        <Grid Grid.Row="0"
              Background="{DynamicResource SecondaryBackgroundBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="Настройки QAMP"
                           Foreground="{DynamicResource ForegroundBrush}"
                           FontWeight="Bold"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="BtnClose"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CancelButton_Click">
                    <Path Data="{StaticResource closeGeometry}"
                          Fill="{DynamicResource AccentBrush}"
                          Stretch="Uniform"
                          Width="18"
                          Height="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Настройки"
                       FontSize="24"
                       FontWeight="Bold"
                       Grid.Row="0"
                       Margin="0,0,0,20"/>

            <!-- Выбор темы -->
            <GroupBox Header="Тема"
                      Grid.Row="1"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                <StackPanel Margin="10">
                    <RadioButton x:Name="DarkThemeRadio"
                                 Content="Темная"
                                 GroupName="Theme"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="ThemeRadio_Checked"/>
                    <RadioButton x:Name="LightThemeRadio"
                                 Content="Светлая"
                                 GroupName="Theme"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="ThemeRadio_Checked"/>
                    <RadioButton x:Name="CustomThemeRadio"
                                 Content="Пользовательская"
                                 GroupName="Theme"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="ThemeRadio_Checked"/>
                </StackPanel>
            </GroupBox>

            <!-- Настройка акцентного цвета -->
            <GroupBox Header="Акцентный цвет"
                      Grid.Row="2"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                <StackPanel Margin="10">
                    <TextBlock Text="Выберите цвет (HEX):"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="AccentColorTextBox"
                             Width="200"
                             HorizontalAlignment="Left"
                             TextChanged="AccentColorTextBox_TextChanged"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Background="{DynamicResource TertiaryBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock x:Name="ColorPreview"
                               Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Спектрограмма"
                      Grid.Row="3"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Включить/отключить:"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,10">
                                <RadioButton x:Name="VisualizerEnabled"
                                             Content="Включено"
                                             GroupName="Visualizer"
                                             Margin="0,0,20,0"
                                             Foreground="{DynamicResource ForegroundBrush}"
                                             Checked="VisualizerToggle_Changed"/>
                                <RadioButton x:Name="VisualizerDisabled"
                                             Content="Отключено"
                                             GroupName="Visualizer"
                                             Foreground="{DynamicResource ForegroundBrush}"
                                             Checked="VisualizerToggle_Changed"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="30,0,0,0">
                            <TextBlock Text="Количество столбцов:"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       Margin="0,0,0,5"/>
                            <ComboBox x:Name="BarCountCombo"
                                      Width="100"
                                      
                                      SelectionChanged="BarCountCombo_SelectionChanged">
                                <ComboBoxItem Content="32"/>
                                <ComboBoxItem Content="64"/>
                                              <!-- IsSelected="True"/> -->
                                <ComboBoxItem Content="128"/>
                                <ComboBoxItem Content="256"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Эквалайзер"
                      Grid.Row="4"
                      Margin="0,0,0,30"
                      Foreground="{DynamicResource ForegroundBrush}">
                <Grid Height="Auto">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- График АЧХ -->
                    <Canvas x:Name="EqGraphCanvas"
                            Grid.Row="0"
                            Background="{DynamicResource TertiaryBackgroundBrush}"
                            Margin="10"/>

                    <StackPanel Grid.Row="1">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,5,0,10">
                            <ComboBox x:Name="PresetComboBox"
                                      Width="150"
                                      Margin="0,0,10,0"
                                      SelectionChanged="PresetComboBox_SelectionChanged"
                                      Background="{DynamicResource TertiaryBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}">
                                <ComboBoxItem Content="Пользовательский"/>
                                              <!-- IsSelected="True"/> -->
                                <ComboBoxItem Content="Bass Boost"/>
                                <ComboBoxItem Content="Rock"/>
                                <ComboBoxItem Content="Classical"/>
                                <ComboBoxItem Content="Pop"/>
                            </ComboBox>

                            <Button Content="Сбросить"
                                    Padding="10,5"
                                    Click="ResetEq_Click"
                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"/>
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Auto"
                                      Margin="10,0">
                            <ItemsControl x:Name="EqItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="50"
                                                    Margin="7,0">
                                            <TextBlock Text="{Binding Gain, StringFormat={}{0:0}}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Margin="0,0,0,3"/>

                                            <Slider Orientation="Vertical"
                                                    Height="160"
                                                    Minimum="-12"
                                                    Maximum="12"
                                                    Value="{Binding Gain, Mode=TwoWay}"
                                                    TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="EqSlider_ValueChanged"
                                                    HorizontalAlignment="Center"/>
                                                     <!-- Style="{StaticResource CustomSliderStyle}" -->

                                            <TextBlock Text="{Binding Frequency}"
                                                       FontSize="10"
                                                       FontWeight="Bold"
                                                       Margin="0,5,0,0"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="5"
                      Header="Системные настройки"
                      Margin="0,0,0,20"
                      Foreground="{DynamicResource ForegroundBrush}">
                <StackPanel Margin="10">
                    <RadioButton x:Name="CloseAppRadio"
                                 Content="Закрывать приложение при закрытии"
                                 GroupName="CloseAction"
                                 Margin="0,0,0,10"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="CloseAction_Checked"/>
                    <RadioButton x:Name="CloseToTrayRadio"
                                 Content="Сворачивать в трей при закрытии"
                                 GroupName="CloseAction"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Checked="CloseAction_Checked"/>
                </StackPanel>

            </GroupBox>
            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="Отмена"
                        Width="100"
                        Height="30"
                        Click="CancelButton_Click"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="SaveButton"
                        Content="Сохранить"
                        Width="100"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="SaveButton_Click"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius"
                                    Value="17"/>
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Window>