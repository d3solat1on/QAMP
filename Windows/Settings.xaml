<Window x:Class="QAMP.Windows.Settings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP"
        xmlns:converters="clr-namespace:QAMP.Converters"
        xmlns:viewModels="clr-namespace:QAMP.ViewModels"
        xmlns:services="clr-namespace:QAMP.Services"
        xmlns:dialogs="clr-namespace:QAMP.Dialogs"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{DynamicResource LngSettingsQAMP}"
        SizeToContent="Manual"
        ResizeMode="CanMinimize"
        Height="900"
        Width="1100"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="EqSliderThumbStyle"
               TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{DynamicResource AccentBrush}"
                                Width="8"
                                Height="16"
                                CornerRadius="{DynamicResource AppCornerRadius}"
                                RenderOptions.EdgeMode="Aliased">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  BlurRadius="6"
                                                  ShadowDepth="1"
                                                  Opacity="0.8"/>
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomSliderStyle"
               TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border x:Name="TrackBackground"
                                    Background="{DynamicResource TertiaryBackgroundBrush}"
                                    Width="4"
                                    HorizontalAlignment="Center"
                                    CornerRadius="{DynamicResource AppCornerRadius}"
                                    Opacity="0.6"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EqSliderThumbStyle}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBox"
               TargetType="ComboBox">
            <Setter Property="Background"
                    Value="Black"/>
            <Setter Property="Foreground"
                    Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource AccentBrush}"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Background="Black"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30"
                      GlassFrameThickness="0"
                      CornerRadius="{DynamicResource AppCornerRadius}"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Строка заголовка -->
        <Grid Grid.Row="0"
              Background="{DynamicResource SecondaryBackgroundBrush}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="10,0,0,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock
                    Text="{DynamicResource LngSettingsQAMP}"
                    Foreground="{DynamicResource ForegroundBrush}"
                    FontWeight="Bold"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="BtnClose"
                        Style="{StaticResource CloseButtonStyle}"
                        Click="CancelButton_Click">
                    <Path Data="{StaticResource closeGeometry}"
                          Fill="{DynamicResource AccentBrush}"
                          Stretch="Uniform"
                          Width="18"
                          Height="18"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock
                    Text="{DynamicResource LngSettingsTitle}"
                    FontSize="24"
                    FontWeight="Bold"
                    Grid.Row="0"
                    Margin="0,0,0,20"/>

                <!-- Выбор темы -->
                <GroupBox x:Name="Theme"
                          Header="{DynamicResource LngTheme}"
                          Grid.Row="1"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="DarkThemeRadio"
                                     Content="{DynamicResource LngDarkTheme}"
                                     GroupName="Theme"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="StandardThemeRadio_Checked"/>

                        <RadioButton x:Name="LightThemeRadio"
                                     Content="{DynamicResource LngLightTheme}"
                                     GroupName="Theme"
                                     Margin="0,0,0,15"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="StandardThemeRadio_Checked"/>

                        <RadioButton x:Name="CustomThemeRadio"
                                     Content="{DynamicResource LngCustomTheme}"
                                     GroupName="Theme"
                                     Margin="0,0,0,15"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CustomThemeRadio_Checked"/>

                        <TextBlock x:Name="CustomThemeRadio1"
                                   Text="{DynamicResource LngCustomThemes}"
                                   Margin="0,0,0,5"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   FontSize="11"
                                   Opacity="0.7"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="CustomThemesComboBox"
                                      Grid.Column="0"
                                      Margin="0,0,10,0"
                                      Height="25"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="CustomThemesComboBox_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource ForegroundBrush}"/>
                                        <Setter Property="Background"
                                                Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <Button x:Name="AddThemeButton"
                                    Grid.Column="1"
                                    Style="{StaticResource ModernPlayerButton}"
                                    Content="{DynamicResource LngAddTheme}"
                                    Padding="10,0"
                                    Height="25"
                                    Click="AddThemeButton_Click"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Настройка акцентного цвета -->

                <!-- Language selection -->
                <GroupBox x:Name="LanguageGroup"
                          Grid.Row="6"
                          Header="{DynamicResource LngLanguage}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="LanguageRuRadio"
                                     Content="{DynamicResource LngLanguageRussian}"
                                     GroupName="Language"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Margin="0,0,0,10"
                                     Checked="LanguageRadio_Checked"/>
                        <RadioButton x:Name="LanguageEnRadio"
                                     Content="{DynamicResource LngLanguageEnglish}"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     GroupName="Language"
                                     Checked="LanguageRadio_Checked"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="MainColor"
                          Header="{DynamicResource AccentColor}"
                          Grid.Row="2"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="SelectColor"
                                   Text="{DynamicResource LngMainColor}"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="AccentColorTextBox"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 TextChanged="AccentColorTextBox_TextChanged"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Background="{DynamicResource TertiaryBackgroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <TextBlock x:Name="ColorPreview"
                                   Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="Spectrum"
                          Header="{DynamicResource LngSpectrum}"
                          Grid.Row="3"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="VisualizerEnabled"
                                     Content="{DynamicResource LngVisualizerEnabled}"
                                     GroupName="Visualizer"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="VisualizerToggle_Changed"/>
                        <RadioButton x:Name="VisualizerDisabled"
                                     Content="{DynamicResource LngVisualizerDisabled}"
                                     GroupName="Visualizer"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="VisualizerToggle_Changed"/>
                    </StackPanel>
                </GroupBox>


                <GroupBox x:Name="FormatLibrary"
                          Grid.Row="5"
                          Header="{DynamicResource LngFormatLibrary}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="DefaultModeRadio"
                                     Content="{DynamicResource LngDefaultMode}"
                                     GroupName="Format"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="Format_Checked"/>
                        <RadioButton x:Name="CompactModeRadio"
                                     Content="{DynamicResource LngCompactMode}"
                                     GroupName="Format"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="Format_Checked"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="SystemSettings"
                          Grid.Row="8"
                          Header="{DynamicResource LngSystemSettings}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="CloseAppRadio"
                                     Content="{DynamicResource LngCloseApp}"
                                     GroupName="CloseAction"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CloseAction_Checked"/>
                        <RadioButton x:Name="CloseToTrayRadio"
                                     Content="{DynamicResource LngCloseToTrayApp}"
                                     GroupName="CloseAction"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CloseAction_Checked"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="Dopolnitelno"
                          Grid.Row="7"
                          Header="{DynamicResource LngDopolnitelno}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="AdaptiveGradientsRadio"
                                     Content="{DynamicResource LngAdaptiveGradients}"
                                     GroupName="AdaptiveGradients"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="AdaptiveGradients_Checked"/>
                        <RadioButton x:Name="StaticGradientsRadio"
                                     Content="{DynamicResource LngStaticGradients}"
                                     GroupName="AdaptiveGradients"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="AdaptiveGradients_Checked"/>

                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="SystemGroupBox"
                          Grid.Row="10"
                          Header="{DynamicResource LngSystem}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10"
                                HorizontalAlignment="Left">
                        <Button Style="{StaticResource ModernPlayerButton}"
                                x:Name="DatabaseLocation"
                                Margin="0,0,0,10"
                                Width="Auto"
                                Height="30"
                                Content="{DynamicResource LngOpenDataBase}"
                                Click="OpenDatabaseLocation_Click">
                        </Button>
                        <Button Style="{StaticResource ModernPlayerButton}"
                                x:Name="AppLocation"
                                Margin="0,0,0,10"
                                Width="Auto"
                                Height="30"
                                Content="{DynamicResource LngOpenAppLocation}"
                                Click="OpenAppLocation_Click">
                        </Button>
                        <Button Style="{StaticResource ModernPlayerButton}"
                                x:Name="ReplaceBG"
                                Width="Auto"
                                Height="30"
                                Content="{DynamicResource LngReplaceBG}"
                                Click="ReplaceBG_Click">
                        </Button>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="BG"
                          Grid.Row="11"
                          Header="{DynamicResource LngBG}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="NotUseCustomBGradio"
                                     Content="{DynamicResource LngUseDefaultBG}"
                                     GroupName="BgGroup"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CheckUseCustomBG"/>
                        <RadioButton x:Name="UseCustomBGradio"
                                     Content="{DynamicResource LngUseCustomBG}"
                                     GroupName="BgGroup"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CheckUseCustomBG"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="CornerRadius"
                          Grid.Row="12"
                          Header="{DynamicResource LngRounding}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="SelectNumber"
                                   Text="{DynamicResource LngRoundingEnter}"
                                   ToolTip="{DynamicResource LngErrorMessageRound}"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="CurrentRoundTextBox"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 TextChanged="CurrentRound_TextChanged"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 Background="{DynamicResource TertiaryBackgroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="AutoLaunch"
                          Grid.Row="9"
                          Header="{DynamicResource LngAutoLauch}"
                          Margin="0,0,0,20"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <StackPanel Margin="10">
                        <RadioButton x:Name="AutoLaunchEnabled"
                                     Content="{DynamicResource LngAutoLaunchOn}"
                                     GroupName="AutoLaunch"
                                     Margin="0,0,0,10"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CheckAutoLaunch"/>
                        <RadioButton x:Name="AutoLaunchDisabled"
                                     Content="{DynamicResource LngAutoLaunchOff}"
                                     GroupName="AutoLaunch"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Checked="CheckAutoLaunch"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </ScrollViewer>
        <Grid Grid.Row="2"
              Background="{DynamicResource SecondaryBackgroundBrush}">
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Right">
                <TextBlock x:Name="usingRAM"
                           Text=""
                           Width="250"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Background="Transparent"
                           Foreground="{DynamicResource ForegroundBrush}"
                           FontWeight="Bold"
                           Visibility="Collapsed"/>
                <Button Style="{StaticResource ModernPlayerButton}"
                        x:Name="Statistics"
                        Content="{DynamicResource LngStatistics}"
                        Margin="5,0,0,0"
                        Click="StatisticsButton_Click"
                        Width="100"
                        Height="35">
                </Button>
                <Button Style="{StaticResource ModernPlayerButton}"
                        x:Name="HelpWindowButton"
                        Content="{DynamicResource LngOpenHelpWindow}"
                        Margin="5,0,0,0"
                        Click="HelpWindowButton_Click"
                        Width="100"
                        Height="35">
                </Button>
                <Button Style="{StaticResource ModernPlayerButton}"
                        x:Name="CancelButton"
                        Content="{DynamicResource LngCancelButton}"
                        Click="CancelButton_Click"
                        Margin="5,0,0,0"
                        Width="100"
                        Height="35">

                </Button>
                <Button Style="{StaticResource ModernPlayerButton}"
                        x:Name="SaveButton"
                        Content="{DynamicResource LngSaveButton}"
                        Width="100"
                        Height="35"
                        Margin="5,0,0,0"
                        Click="SaveButton_Click">
                </Button>
            </StackPanel>
            <dialogs:ModernNotice x:Name="SettingsInfoToast"
                                  VerticalAlignment="Bottom"
                                  HorizontalAlignment="Center"
                                  Panel.ZIndex="9999"/>
        </Grid>
    </Grid>
</Window>