<Window x:Class="QAMP.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP"
        Title="{DynamicResource LngHelpAndSupport}"
        SizeToContent="WidthAndHeight"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HelpAndSupport"
            Text="{DynamicResource LngHelpAndSupport}"
                   FontSize="24"
                   Foreground="{DynamicResource ForegroundBrush}"
                   Margin="0,0,0,15"/>
        <!-- Стрелка вправо - 5 сек вперед -->
        <!-- Стрелка влево - 5 сек назад -->
        <!-- Пробел - Пауза/Плей -->
        <!-- Ctrl+N - Некст трек -->
        <!-- Ctrl+B - Пред. трек -->
        <!-- Дефолт клавиши FN+F1,F2,F3 -->
        <!-- Лирикс мод - L -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox x:Name="HotKeys"
                          Header="{DynamicResource LngHotKeys}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <TextBlock x:Name="HotKeysTextBlock"
                               Text="{DynamicResource LngHotKeysTextBlock}"
                               Margin="10"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </GroupBox>

                <GroupBox x:Name="AboutProgramm"
                          Header="{DynamicResource LngAboutProgramm}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <TextBlock TextWrapping="Wrap"
                               Margin="10"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Text="{DynamicResource LngDescQAMP}">
                    </TextBlock>
                </GroupBox>
                <GroupBox x:Name="Support"
                          Header="{DynamicResource LngSupport}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <TextBlock TextWrapping="Wrap"
                               Margin="10"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Text="{DynamicResource LngHelpGitHub}">
                    </TextBlock>
                </GroupBox>
                <GroupBox x:Name="LibrariesUsed"
                          Header="{DynamicResource LngLibrariesUsed}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                        <Run x:Name="Visualization"
                             Text="{DynamicResource LngVisualization}"/>
                        <Hyperlink NavigateUri="https://scottplot.net/"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            ScottPlot
                        </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                        <Run x:Name="Audio"
                             Text="{DynamicResource LngAudio}"/>
                        <Hyperlink NavigateUri="http://www.un4seen.com"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            BASS Audio Library (Bass.Net)
                        </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run x:Name="Metadata"
                                 Text="{DynamicResource LngMetaData}"/>
                            <Hyperlink NavigateUri="https://github.com/mono/taglib-sharp"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                TagLibSharp
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run x:Name="Icons"
                                 Text="{DynamicResource LngIcons}"/>
                            <Hyperlink NavigateUri="https://fonts.google.com/icons"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Google Material Icons
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run x:Name="GraphicsUI"
                                 Text="{DynamicResource LngGraphicsUI}"/>
                            <Hyperlink NavigateUri="https://github.com/KSemenenko/ColorThief"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                ColorThief
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run x:Name="Lirycs"
                                 Text="{DynamicResource LngLirycs}"/>
                            <Hyperlink NavigateUri="https://lrclib.net/"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                LrcLib
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run x:Name="DataBase"
                                 Text="{DynamicResource LngDataBase}"/>
                            <Hyperlink NavigateUri="https://learn.microsoft.com/en-us/dotnet/standard/data/sqlite/?tabs=net-cli"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Microsoft.Data.Sqlite
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <TextBox x:Name="CurrentVersion"
                     Width="100"
                     Height="35"
                     Background="{DynamicResource AccentBrush}"
                     Foreground="{DynamicResource BackgroundBrush}"
                     FontWeight="Bold">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="{DynamicResource AppCornerRadius}"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Button x:Name="CloseButton"
                    Content="{DynamicResource LngCloseButton}"
                    Margin="5,0,0,0"
                    Click="CloseButton_Click"
                    Width="100"
                    Height="35"
                    Style="{StaticResource ModernPlayerButton}">
            </Button>
            <Button Content="GitHub"
                    Margin="5,0,0,0"
                    Click="GitHubButton_Click"
                    Width="100"
                    Height="35"
                    Style="{StaticResource ModernPlayerButton}">
            </Button>
        </StackPanel>
    </Grid>
</Window>