<Window x:Class="QAMP.Windows.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QAMP"
        Title="Справка - QAMP"
        SizeToContent="WidthAndHeight"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Справка и поддержка"
                   FontSize="24"
                   Foreground="{DynamicResource ForegroundBrush}"
                   Margin="0,0,0,15"/>
        <!-- Стрелка вправо - 5 сек вперед -->
        <!-- Стрелка влево - 5 сек назад -->
        <!-- Пробел - Пауза/Плей -->
        <!-- Ctrl+N - Некст трек -->
        <!-- Ctrl+B - Пред. трек -->
        <!-- Дефолт клавиши FN+F1,F2,F3 -->
        <!-- Лирикс мод - L -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Горячие клавиши"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <TextBlock Text="
                    Ctrl+Пробел - Пауза/Плей&#x0a;
                    Ctrl+N - След. трек&#x0a;
                    Ctrl+B - Пред. трек&#x0a;
                    Ctrl+L - Режим текста&#x0a;
                    Ctrl+F - Добавить в избранное/убрать из избранного&#x0a;
                    Ctrl+L - Режим текста&#x0a;
                    Ctrl+I - Информация о треке&#x0a;
                    Ctrl+R - Повтор трека&#x0a;
                    Ctrl+S - Перемешивание треков&#x0a;
                    Ctrl+Tab - Переключение между ячейками в плейлисте&#x0a;
                    Ctrl+Стрелка вправо - 5 сек вперед&#x0a;
                    Ctrl+Стрелка влево - 5 сек назад&#x0a;
                    FN+F1 - Плей/Пауза &#x0a;
                    FN+F2 - След. трек &#x0a;
                    FN+F3 - Пред. трек &#x0a;
                    (*Клавиши FN зависят от производителя компьютера/ноутбука/клавиатуры и т.п.*)"
                               Margin="10"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </GroupBox>

                <GroupBox Header="О программе"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <TextBlock TextWrapping="Wrap"
                               Margin="10"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Text="QAMP (Quick Attractive Media Player) - современный аудиоплеер с открытым исходным кодом.">
                    </TextBlock>
                </GroupBox>
                <GroupBox Header="Поддержка"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <TextBlock TextWrapping="Wrap"
                               Margin="10"
                               Foreground="{DynamicResource ForegroundBrush}"
                               Text="Если у вас возникли вопросы или проблемы, пожалуйста, посетите наш репозиторий на GitHub для получения поддержки и информации о проекте.">
                    </TextBlock>
                </GroupBox>
                <GroupBox Header="Используемые библиотеки"
                          Foreground="{DynamicResource ForegroundBrush}"
                          Margin="0,10">
                    <StackPanel Margin="10">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                        <Run Text="Визуализация построена на "/>
                        <Hyperlink NavigateUri="https://scottplot.net/"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            ScottPlot
                        </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                        <Run Text="Аудио обработка - "/>
                        <Hyperlink NavigateUri="https://github.com/naudio/NAudio"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            NAudio
                        </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run Text="Работа с метаданными - "/>
                            <Hyperlink NavigateUri="https://github.com/mono/taglib-sharp"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                TagLibSharp
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run Text="Ресурсы иконок - "/>
                            <Hyperlink NavigateUri="https://fonts.google.com/icons"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Google Material Icons
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run Text="Графический интерфейс - "/>
                            <Hyperlink NavigateUri="https://github.com/KSemenenko/ColorThief"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                ColorThief
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run Text="Тексты песен - "/>
                            <Hyperlink NavigateUri="https://lrclib.net/"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                LrcLib
                            </Hyperlink>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource ForegroundBrush}">
                            <Run Text="База данных - "/>
                            <Hyperlink NavigateUri="https://learn.microsoft.com/en-us/dotnet/standard/data/sqlite/?tabs=net-cli"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Microsoft.Data.Sqlite
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Закрыть"
                    Click="CloseButton_Click"
                    Width="80"
                    Margin="5"
                    Background="{DynamicResource AccentBrush}"/>
            <Button Content="GitHub"
                    Click="GitHubButton_Click"
                    Width="80"
                    Margin="5"
                    Background="{DynamicResource AccentBrush}"/>
        </StackPanel>
    </Grid>
</Window>